# =============================================================================
# 云端书院 — 环境变量示例（复制为 .env 后填入真实值，勿提交 .env）
# 详细说明见 docs/运维/环境变量说明.md
#
# ⚠️  staging / prod 部署：复制本文件后【第一项必改】
#     SPRING_PROFILES_ACTIVE=staging  或  SPRING_PROFILES_ACTIVE=prod
#     若仍为 dev/docker/空，将绕过 JWT、微信 dev-mode、默认超管等启动门禁。
#     发布前请执行：npm run check:release-all -- --env /path/to/.env
# =============================================================================

# --- Spring Profile ---
# dev | docker | staging | prod | test
# 本地开发可保持 dev；预发/生产必须改为 staging 或 prod
SPRING_PROFILES_ACTIVE=dev

# --- 服务 ---
SERVER_PORT=8080
APP_VERSION=0.0.1-SNAPSHOT

# --- MySQL（staging / prod 必填）---
DB_URL=jdbc:mysql://localhost:3306/shuyuan?useUnicode=true&characterEncoding=UTF-8&connectionCollation=utf8mb4_unicode_ci&serverTimezone=Asia/Shanghai
DB_USERNAME=root
DB_PASSWORD=your-db-password

# --- Redis（staging / prod 必填）---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DATABASE=0

# --- JWT（staging / prod 必填，至少 32 字符随机串）---
JWT_SECRET=your-jwt-secret-at-least-32-chars
JWT_EXPIRE_DAYS=7

# --- 微信小程序（prod 必填）---
WX_APPID=your-wx-appid
WX_SECRET=your-wx-secret

# --- 微信订阅消息模板 ID（公众平台申请后填入，dev 可留空走日志/mock）---
WX_TMPL_ENROLL_SUCCESS=
WX_TMPL_ENROLL_APPROVED=
WX_TMPL_ACTIVITY_REMIND=

# --- 阿里云 OSS / CDN（staging / prod 媒体主链建议配置）---
OSS_ENABLED=false
OSS_ENDPOINT=https://oss-cn-guizhou.aliyuncs.com
OSS_BUCKET=shuyuan-assets
OSS_ACCESS_KEY=your-oss-access-key
OSS_SECRET_KEY=your-oss-secret-key
OSS_CDN_DOMAIN=https://cdn.shuyuan.example.com
OSS_SIGN_EXPIRE_SECONDS=7200
OSS_MAX_UPLOAD_BYTES=209715200

# --- 登录防刷（可选，有默认值）---
LOGIN_MAX_FAIL_ATTEMPTS=5
LOGIN_LOCK_MINUTES=5
LOGIN_FAIL_WINDOW_MINUTES=15

# --- 测试专用（application-test.yml，CI 阶段 B）---
TEST_DB_URL=jdbc:mysql://localhost:3306/shuyuan_test?useUnicode=true&characterEncoding=UTF-8&connectionCollation=utf8mb4_unicode_ci&serverTimezone=Asia/Shanghai
TEST_DB_USERNAME=root
TEST_DB_PASSWORD=dev123456
TEST_REDIS_HOST=localhost
TEST_REDIS_PORT=6379
TEST_REDIS_PASSWORD=dev123456
TEST_REDIS_DATABASE=1

# --- Admin 前端（构建时注入，PR2+ 可扩展）---
# VITE_API_BASE_URL=http://localhost:8080/api/v1

# --- CORS（仅前后端分域部署时需要；同源反代可留空）---
# 逗号分隔，映射为 shuyuan.cors.allowed-origin-patterns
# SHUYUAN_CORS_ALLOWED_ORIGIN_PATTERNS=https://admin-staging.your-domain.edu.cn

# --- 小程序（miniapp/config/env.js，PR3 接入）---
# MINIAPP_ENV=dev
