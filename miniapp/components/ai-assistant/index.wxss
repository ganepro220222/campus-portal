/* 文化问答浮标 + 底部抽屉 */
.ai-fab {
  position: fixed;
  right: 32rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #3F57B5, #2B356E);
  box-shadow: 0 20rpx 48rpx rgba(43, 53, 110, 0.42);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 400;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}
.ai-fab:active { transform: scale(0.94); }
.pulse {
  position: absolute;
  left: -4rpx; top: -4rpx; right: -4rpx; bottom: -4rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(190, 156, 68, 0.6);
  animation: aiPulse 2.2s infinite;
}
@keyframes aiPulse {
  0%   { transform: scale(1);   opacity: 0.7; }
  70%  { transform: scale(1.4); opacity: 0; }
  100% { opacity: 0; }
}
.ai-badge {
  position: absolute;
  top: -8rpx; right: -8rpx;
  background: #BE9C44;
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
  padding: 3rpx 12rpx;
  border-radius: 20rpx;
  border: 3rpx solid #fff;
}

.mask {
  position: fixed;
  left: 0; top: 0; right: 0; bottom: 0;
  background: rgba(15, 20, 46, 0.45);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
  z-index: 600;
}
.mask.show { opacity: 1; pointer-events: auto; }

.sheet {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  height: 80vh;
  background: #fff;
  border-radius: 44rpx 44rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.36s cubic-bezier(0.32, 0.72, 0, 1);
  z-index: 610;
  display: flex;
  flex-direction: column;
}
.sheet.show { transform: translateY(0); }

.sheet-head {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 32rpx 36rpx 20rpx;
  border-bottom: 1rpx solid var(--line);
}
.avt {
  width: 76rpx; height: 76rpx; border-radius: 50%;
  background: linear-gradient(135deg, #3F57B5, #2B356E);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.sheet-head-txt { flex: 1; }
.sheet-title { font-weight: 700; color: var(--ink); font-size: 30rpx; }
.sheet-sub { font-size: 22rpx; color: var(--muted); margin-top: 4rpx; }
.sheet-close {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  transform: rotate(90deg);
}

.sheet-body {
  flex: 1;
  min-height: 0;
  padding: 28rpx 32rpx;
  box-sizing: border-box;
}
.bubble {
  max-width: 80%;
  padding: 22rpx 28rpx;
  border-radius: 28rpx;
  font-size: 27rpx;
  line-height: 1.6;
  margin-bottom: 24rpx;
  word-break: break-word;
}
.bubble.ai {
  background: var(--sky-3);
  color: var(--ink);
  border-top-left-radius: 8rpx;
  border: 1rpx solid var(--line);
}
.bubble.me {
  background: linear-gradient(135deg, #3F57B5, #2B356E);
  color: #fff;
  border-top-right-radius: 8rpx;
  margin-left: auto;
}
.chips { display: flex; flex-wrap: wrap; gap: 16rpx; }
.chip {
  font-size: 24rpx;
  padding: 14rpx 24rpx;
  border-radius: 32rpx;
  background: #fff;
  color: var(--navy);
  border: 1rpx solid var(--sky);
}
.chip:active { background: var(--sky-3); }

.sheet-input {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 28rpx calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--line);
}
.ai-input {
  flex: 1;
  height: 84rpx;
  border: 1rpx solid var(--line);
  border-radius: 42rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  background: var(--paper);
}
.ai-ph { color: var(--muted); }
.send {
  width: 84rpx; height: 84rpx; border-radius: 50%;
  background: linear-gradient(135deg, #3F57B5, #2B356E);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.send:active { opacity: 0.85; }
