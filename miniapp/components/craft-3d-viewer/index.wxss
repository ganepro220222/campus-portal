.viewer-shell {
  position: relative;
  border-radius: 28rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #EEF2FA, #F8FAFE);
}

.viewer-mask {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(245, 248, 252, 0.72);
  font-size: 24rpx;
  color: #5A648A;
  pointer-events: none;
}
