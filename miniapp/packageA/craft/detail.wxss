/* packageA/craft/detail.wxss */
.detail-page { height: 100vh; display: flex; flex-direction: column; background: #F5F8FC; }
.detail-scroll { flex: 1; overflow: hidden; }
.detail-wrap { padding: 24rpx 28rpx 0; }
.detail-bottom { height: calc(60rpx + env(safe-area-inset-bottom)); }

/* 图集 */
.gal { border-radius: 28rpx; overflow: hidden; box-shadow: var(--shadow); position: relative; }
.gal-3d { margin-bottom: 0; }
.gslides { height: 460rpx; }
.gimg { height: 460rpx; display: flex; align-items: center; justify-content: center; position: relative; }
.gimg-img { width: 100%; height: 100%; }
.gi1 { background: linear-gradient(135deg, #2B356E, #475BA6); }
.gi2 { background: linear-gradient(135deg, #5A4E86, #7E72B0); }
.gi3 { background: linear-gradient(135deg, #365E8C, #2E7C8C); }
.gcap {
  position: absolute;
  left: 0; right: 0; bottom: 0;
  padding: 48rpx 28rpx 22rpx;
  z-index: 2;
  background: linear-gradient(transparent, rgba(12, 16, 36, 0.7));
  color: #fff;
  font-size: 23rpx;
}

/* 介绍 */
.craft-intro {
  background: #fff;
  border: 1rpx solid var(--line);
  border-radius: 28rpx;
  padding: 28rpx;
  margin-top: 24rpx;
  box-shadow: var(--shadow-sm);
}
.ci-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}
.ci-title { font-size: 38rpx; font-weight: 700; color: var(--ink); flex: 1; }
.lang-switch {
  display: flex;
  border: 1rpx solid var(--line);
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
}
.lang-btn {
  padding: 10rpx 20rpx;
  font-size: 22rpx;
  color: var(--muted);
  background: #fff;
}
.lang-btn.lang-on {
  background: var(--sky-2);
  color: var(--navy);
  font-weight: 700;
}
.ci-tags { display: flex; gap: 14rpx; margin: 18rpx 0 22rpx; }
.ci-body { font-size: 27rpx; line-height: 1.9; color: var(--ink); text-align: justify; }

/* 联系方式 */
.contact {
  background: #fff;
  border: 1rpx solid var(--line);
  border-radius: 28rpx;
  padding: 12rpx 28rpx;
  margin-top: 24rpx;
  box-shadow: var(--shadow-sm);
}
.contact-title { font-size: 30rpx; font-weight: 700; color: var(--ink); padding: 18rpx 0 10rpx; }
.c-row { display: flex; align-items: center; gap: 20rpx; padding: 20rpx 0; border-top: 1rpx solid var(--line); }
.c-row:active { opacity: 0.7; }
.c-ic {
  width: 64rpx; height: 64rpx;
  border-radius: 18rpx;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.c-blue { background: linear-gradient(135deg, #3F57B5, #2B356E); }
.c-green { background: linear-gradient(135deg, #3F9A6B, #2E7C55); }
.c-gold { background: linear-gradient(135deg, #CDA94E, #B58A2F); }
.c-body { flex: 1; min-width: 0; }
.c-k { font-size: 22rpx; color: var(--muted); display: block; }
.c-v { font-size: 27rpx; color: var(--ink); font-weight: 500; margin-top: 4rpx; display: block; }
.c-act { font-size: 22rpx; color: var(--navy); font-weight: 600; flex-shrink: 0; }

/* 海报按钮：居中、随内容宽度，上限不超过卡片 */
.poster-btn-wrap {
  display: flex;
  justify-content: center;
  margin-top: 26rpx;
}
.poster-btn {
  width: auto;
  max-width: 100%;
  box-sizing: border-box;
  margin: 0;
  padding: 0 32rpx;
  height: 92rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #CDA94E, #B58A2F);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  white-space: nowrap;
  overflow: hidden;
  box-shadow: 0 16rpx 44rpx rgba(150, 110, 30, 0.35);
}
.poster-btn text {
  flex-shrink: 0;
  white-space: nowrap;
  line-height: 1.3;
}
.poster-btn::after { border: none; }
