/* packageA/craft/list.wxss */
.craft-page {
  height: 100vh;
  background: linear-gradient(180deg, #EAF1FB 0, #F5F8FC 240rpx);
}
.craft-scroll { height: 100%; overflow: hidden; }

.craft-intro { padding: 28rpx 32rpx 4rpx; }
.ci-zh { font-size: 34rpx; font-weight: 700; color: var(--ink); display: block; }
.ci-en { font-size: 20rpx; color: var(--muted); letter-spacing: 1rpx; margin-top: 6rpx; display: block; }

.craft-grid {
  padding: 20rpx 32rpx 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}
.ccard {
  border-radius: 26rpx;
  overflow: hidden;
  background: #fff;
  border: 1rpx solid var(--line);
  box-shadow: 0 8rpx 22rpx rgba(31, 40, 90, 0.10);
  transition: transform 0.15s;
}
.ccard:active { transform: translateY(-4rpx); }
.ccard-cover {
  position: relative;
  height: 210rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.ccard-bg { position: absolute; left: 0; top: 0; right: 0; bottom: 0; }
.ccard-img { width: 100%; height: 100%; opacity: 0.42; }
.ccard-badge {
  position: absolute;
  top: 14rpx; right: 14rpx;
  font-size: 18rpx;
  font-weight: 700;
  color: #fff;
  background: rgba(12, 16, 36, 0.32);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  padding: 3rpx 12rpx;
  border-radius: 16rpx;
}
.ccard-foot { padding: 18rpx 20rpx 22rpx; }
.ccard-name { font-size: 27rpx; font-weight: 700; color: var(--ink); display: block; }
.ccard-desc {
  font-size: 21rpx;
  color: var(--muted);
  margin-top: 8rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.ccard-foot .pill { margin-top: 14rpx; }

.list-bottom { height: calc(60rpx + env(safe-area-inset-bottom)); }
