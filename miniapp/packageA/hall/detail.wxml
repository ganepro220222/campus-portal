<!-- packageA/hall/detail.wxml -->
<view class="detail-page">
  <scroll-view scroll-y class="detail-scroll" enhanced show-scrollbar="{{false}}">
    <view class="detail-wrap">

      <!-- 画廊轮播 -->
      <view class="gal">
        <swiper class="gslides" circular bindchange="onGallery" indicator-dots indicator-color="rgba(255,255,255,.4)" indicator-active-color="#ffffff">
          <swiper-item wx:for="{{hall.slides}}" wx:key="index">
            <view
              class="gimg {{item.cls}}"
              bindtap="onPreviewSlide"
              data-url="{{item.imageUrl}}"
            >
              <image wx:if="{{item.imageUrl}}" class="gimg-photo" src="{{item.imageUrl}}" mode="aspectFill" />
              <icon wx:else name="{{item.icon}}" size="54" color="rgba(255,255,255,0.55)" />
            </view>
          </swiper-item>
        </swiper>
        <view class="gcap">{{currentCaption}}</view>
      </view>

      <!-- VR 展厅入口 -->
      <view class="vr-block">
        <button class="vr-btn {{hall.vrReady ? '' : 'vr-btn-off'}}" bindtap="onEnterVr">
          <icon name="museum" size="20" color="#ffffff" />
          <text>{{hall.vrReady ? '进入 VR 展厅' : 'VR 链接筹备中'}}</text>
        </button>
        <text wx:if="{{hall.vrReady}}" class="vr-hint">720 云全景漫游 · 建议在 Wi-Fi 环境下体验</text>
      </view>

      <!-- 语音讲解 -->
      <view class="audio">
        <view class="ap {{audioPlaying ? 'ap-on' : ''}}" bindtap="onAudio">
          <icon wx:if="{{audioPlaying}}" name="pause" size="18" color="#ffffff" />
          <icon wx:else name="play" size="18" color="#ffffff" />
        </view>
        <view class="aw {{audioPlaying ? '' : 'aw-paused'}}">
          <view class="wv-bar" wx:for="{{waveBars}}" wx:key="index" style="animation-delay:{{item}}s"></view>
        </view>
        <text class="at">{{hall.audioTime}}</text>
      </view>

      <!-- 展馆介绍 -->
      <view class="hall-intro">
        <view class="hi-title serif">{{hall.name}}</view>
        <view wx:if="{{hall.shortName && hall.shortName !== hall.name}}" class="hi-sub">{{hall.shortName}}</view>
        <view class="hi-p">{{hall.intro}}</view>
        <view class="poster-btn-wrap">
          <button class="poster-btn" bindtap="onPoster">
            <icon name="poster" size="18" color="#ffffff" />
            <text>一键生成文化分享海报</text>
          </button>
        </view>
      </view>

      <view class="detail-bottom"></view>
    </view>
  </scroll-view>

  <ai-assistant bottom="60" />
</view>
