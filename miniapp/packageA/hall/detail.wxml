<!-- packageA/hall/detail.wxml -->
<view class="detail-page">
  <scroll-view
    scroll-y
    class="detail-scroll"
    enhanced
    show-scrollbar="{{false}}"
    scroll-into-view="{{scrollIntoView}}"
    scroll-with-animation
    bindscroll="onScroll"
  >
    <view class="detail-wrap">

      <!-- 画廊轮播 -->
      <view class="gal">
        <swiper class="gslides" circular bindchange="onGallery" indicator-dots indicator-color="rgba(255,255,255,.4)" indicator-active-color="#ffffff">
          <swiper-item wx:for="{{hall.slides}}" wx:key="index">
            <view
              class="gimg {{item.cls}}"
              bindtap="onPreviewSlide"
              data-url="{{item.imageUrl}}"
            >
              <image wx:if="{{item.imageUrl}}" class="gimg-photo" src="{{item.imageUrl}}" mode="aspectFill" lazy-load />
              <icon wx:else name="{{item.icon}}" size="54" color="rgba(255,255,255,0.55)" />
            </view>
          </swiper-item>
        </swiper>
        <view class="gcap">{{currentCaption}}</view>
      </view>

      <!-- VR 展厅入口 -->
      <view class="vr-block">
        <button class="vr-btn {{hall.vrReady ? '' : 'vr-btn-off'}}" bindtap="onEnterVr">
          <icon name="museum" size="20" color="#ffffff" />
          <text>{{hall.vrReady ? '进入 VR 展厅' : 'VR 链接筹备中'}}</text>
        </button>
        <text wx:if="{{hall.vrReady}}" class="vr-hint">720 云全景漫游 · 建议在 Wi-Fi 环境下体验</text>
      </view>

      <!-- 语音讲解 -->
      <view class="audio">
        <view class="ap {{audioPlaying ? 'ap-on' : ''}}" bindtap="onAudio">
          <icon wx:if="{{audioPlaying}}" name="pause" size="18" color="#ffffff" />
          <icon wx:else name="play" size="18" color="#ffffff" />
        </view>
        <view class="aw {{audioPlaying ? '' : 'aw-paused'}}">
          <view class="wv-bar" wx:for="{{waveBars}}" wx:key="index" style="animation-delay:{{item}}s"></view>
        </view>
        <text class="at">{{hall.audioTime}}</text>
      </view>

      <!-- 展馆简介 -->
      <view class="hall-intro">
        <view class="hi-title serif">{{hall.name}}</view>
        <view wx:if="{{hall.shortName && hall.shortName !== hall.name}}" class="hi-sub">{{hall.shortName}}</view>
        <view class="hi-p">{{hall.intro}}</view>
      </view>

      <!-- 沉浸式长卷：章节分区连续滚动 -->
      <view wx:if="{{hall.hasImmersive}}" class="immersive">
        <view class="imm-head">
          <text class="imm-title serif">沉浸式浏览</text>
          <text class="imm-sub">连续滚动 · 章节分区</text>
        </view>
        <scroll-view scroll-x class="imm-nav" enhanced show-scrollbar="{{false}}">
          <view
            wx:for="{{hall.sections}}"
            wx:key="anchorId"
            class="imm-chip {{activeSectionId === item.anchorId ? 'imm-chip-on' : ''}}"
            data-anchor="{{item.anchorId}}"
            bindtap="onSectionTap"
          >{{item.title}}</view>
        </scroll-view>
        <view class="imm-body">
          <view
            wx:for="{{hall.sections}}"
            wx:key="anchorId"
            id="{{item.anchorId}}"
            class="imm-section"
            data-anchor="{{item.anchorId}}"
          >
            <view class="imm-sec-title">
              <view class="imm-sec-num">{{index + 1}}</view>
              <text class="imm-sec-text serif">{{item.title}}</text>
            </view>
            <view
              wx:for="{{item.items}}"
              wx:for-item="media"
              wx:key="caption"
              class="imm-card"
              bindtap="onPreviewSection"
              data-url="{{media.imageUrl}}"
              data-section="{{item.anchorId}}"
            >
              <view class="imm-img {{media.cls}}">
                <image wx:if="{{media.imageUrl}}" src="{{media.imageUrl}}" mode="aspectFill" class="imm-photo" lazy-load />
                <icon wx:else name="{{media.icon}}" size="48" color="rgba(255,255,255,0.55)" />
              </view>
              <view class="imm-cap">{{media.caption}}</view>
            </view>
          </view>
        </view>
      </view>

      <view class="poster-btn-wrap">
        <button class="poster-btn" bindtap="onPoster">
          <icon name="poster" size="18" color="#ffffff" />
          <text>一键生成文化分享海报</text>
        </button>
      </view>

      <view class="detail-bottom"></view>
    </view>
  </scroll-view>

  <!-- 顶部阅读进度：细线置顶，避让底部海报按钮与 AI 浮标 -->
  <view wx:if="{{hall.hasImmersive}}" class="read-progress">
    <view class="read-progress-bar" style="width: {{scrollProgress}}%;"></view>
  </view>

  <ai-assistant bottom="60" />
</view>
