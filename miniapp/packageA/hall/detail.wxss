/* packageA/hall/detail.wxss */
.detail-page { height: 100vh; display: flex; flex-direction: column; background: #F5F8FC; }
.detail-scroll { flex: 1; overflow: hidden; }
.detail-wrap { padding: 24rpx 28rpx 0; }
.detail-bottom { height: calc(60rpx + env(safe-area-inset-bottom)); }

/* 画廊 */
.gal {
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: var(--shadow);
  position: relative;
}
.gslides { height: 420rpx; }
.gimg {
  height: 420rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}
.gimg-photo {
  width: 100%;
  height: 100%;
}
.gi1 { background: linear-gradient(135deg, #2B356E, #475BA6); }
.gi2 { background: linear-gradient(135deg, #365E8C, #2E7C8C); }
.gi3 { background: linear-gradient(135deg, #5A4E86, #7E72B0); }
.gcap {
  position: absolute;
  left: 0; right: 0; bottom: 0;
  padding: 48rpx 28rpx 24rpx;
  z-index: 2;
  background: linear-gradient(transparent, rgba(12, 16, 36, 0.7));
  color: #fff;
  font-size: 24rpx;
}

/* 语音讲解 */
.audio {
  display: flex;
  align-items: center;
  gap: 22rpx;
  background: #fff;
  border: 1rpx solid var(--line);
  border-radius: 26rpx;
  padding: 22rpx 26rpx;
  margin-top: 24rpx;
  box-shadow: var(--shadow-sm);
}
.ap {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #3F57B5, #2B356E);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  padding-left: 4rpx;
  box-sizing: border-box;
}
.ap-on {
  background: linear-gradient(135deg, #BE9C44, #9A7A2E);
  padding-left: 0;
}
.aw { flex: 1; display: flex; align-items: center; gap: 6rpx; height: 56rpx; }
.aw-paused .wv-bar { animation-play-state: paused; opacity: 0.55; }
.wv-bar {
  flex: 1;
  background: var(--sky);
  border-radius: 4rpx;
  height: 14rpx;
  animation: wv 1.1s ease-in-out infinite;
}
@keyframes wv {
  0%, 100% { height: 14rpx; }
  50% { height: 44rpx; }
}
.at { font-size: 22rpx; color: var(--muted); flex-shrink: 0; }

/* 介绍 */
.hall-intro {
  background: #fff;
  border: 1rpx solid var(--line);
  border-radius: 28rpx;
  padding: 28rpx;
  margin-top: 24rpx;
  box-shadow: var(--shadow-sm);
}
.hi-title { font-size: 38rpx; font-weight: 700; color: var(--ink); }
.hi-p {
  font-size: 27rpx;
  line-height: 1.9;
  color: var(--ink);
  margin-top: 18rpx;
  text-align: justify;
}
/* 海报按钮：居中、随内容宽度，上限不超过卡片 */
.poster-btn-wrap {
  display: flex;
  justify-content: center;
  margin-top: 26rpx;
}
.poster-btn {
  width: auto;
  max-width: 100%;
  box-sizing: border-box;
  margin: 0;
  padding: 0 32rpx;
  height: 92rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #CDA94E, #B58A2F);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  white-space: nowrap;
  overflow: hidden;
  box-shadow: 0 16rpx 44rpx rgba(150, 110, 30, 0.35);
}
.poster-btn text {
  flex-shrink: 0;
  white-space: nowrap;
  line-height: 1.3;
}
.poster-btn::after { border: none; }
