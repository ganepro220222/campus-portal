/* packageA/hall/detail.wxss */
.detail-page { height: 100vh; display: flex; flex-direction: column; background: #F5F8FC; }
.detail-scroll { flex: 1; overflow: hidden; }
.detail-wrap { padding: 24rpx 28rpx 0; }
.detail-bottom { height: calc(60rpx + env(safe-area-inset-bottom)); }

/* 画廊 */
.gal {
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: var(--shadow);
  position: relative;
}
.gslides { height: 420rpx; }
.gimg {
  height: 420rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}
.gimg-photo {
  width: 100%;
  height: 100%;
}
.gi1 { background: linear-gradient(135deg, #2B356E, #475BA6); }
.gi2 { background: linear-gradient(135deg, #365E8C, #2E7C8C); }
.gi3 { background: linear-gradient(135deg, #5A4E86, #7E72B0); }
.gcap {
  position: absolute;
  left: 0; right: 0; bottom: 0;
  padding: 48rpx 28rpx 24rpx;
  z-index: 2;
  background: linear-gradient(transparent, rgba(12, 16, 36, 0.7));
  color: #fff;
  font-size: 24rpx;
  line-height: 1.45;
}

/* VR 入口 */
.vr-block {
  margin-top: 24rpx;
  background: #fff;
  border: 1rpx solid var(--line);
  border-radius: 26rpx;
  padding: 24rpx 26rpx;
  box-shadow: var(--shadow-sm);
}
.vr-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #3F57B5, #2B356E);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  line-height: 1;
}
.vr-btn::after { border: none; }
.vr-btn-off {
  background: #E8ECF4;
  color: #8A93B2;
}
.vr-hint {
  display: block;
  margin-top: 14rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--muted);
}

/* 语音讲解 */
.audio {
  display: flex;
  align-items: center;
  gap: 22rpx;
  background: #fff;
  border: 1rpx solid var(--line);
  border-radius: 26rpx;
  padding: 22rpx 26rpx;
  margin-top: 24rpx;
  box-shadow: var(--shadow-sm);
}
.ap {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #3F57B5, #2B356E);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  padding-left: 4rpx;
  box-sizing: border-box;
}
.ap-on {
  background: linear-gradient(135deg, #BE9C44, #9A7A2E);
  padding-left: 0;
}
.aw { flex: 1; display: flex; align-items: center; gap: 6rpx; height: 56rpx; }
.aw-paused .wv-bar { animation-play-state: paused; opacity: 0.55; }
.wv-bar {
  flex: 1;
  background: var(--sky);
  border-radius: 4rpx;
  height: 14rpx;
  animation: wv 1.1s ease-in-out infinite;
}
@keyframes wv {
  0%, 100% { height: 14rpx; }
  50% { height: 44rpx; }
}
.at { font-size: 22rpx; color: var(--muted); flex-shrink: 0; }

/* 介绍 */
.hall-intro {
  background: #fff;
  border: 1rpx solid var(--line);
  border-radius: 28rpx;
  padding: 28rpx;
  margin-top: 24rpx;
  box-shadow: var(--shadow-sm);
}
.hi-title { font-size: 38rpx; font-weight: 700; color: var(--ink); line-height: 1.35; }
.hi-sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--muted);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.hi-p {
  font-size: 27rpx;
  line-height: 1.9;
  color: var(--ink);
  margin-top: 18rpx;
  text-align: justify;
}
/* 海报按钮：居中、随内容宽度，上限不超过卡片 */
.poster-btn-wrap {
  display: flex;
  justify-content: center;
  margin-top: 26rpx;
}
.poster-btn {
  width: auto;
  max-width: 100%;
  box-sizing: border-box;
  margin: 0;
  padding: 0 32rpx;
  height: 92rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #CDA94E, #B58A2F);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  white-space: nowrap;
  overflow: hidden;
  box-shadow: 0 16rpx 44rpx rgba(150, 110, 30, 0.35);
}
.poster-btn text {
  flex-shrink: 0;
  white-space: nowrap;
  line-height: 1.3;
}
.poster-btn::after { border: none; }

/* 沉浸式长卷 */
.immersive {
  margin-top: 24rpx;
  background: #fff;
  border: 1rpx solid var(--line);
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}
.imm-head {
  padding: 28rpx 28rpx 16rpx;
  border-bottom: 1rpx dashed var(--line);
}
.imm-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--ink);
}
.imm-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--muted);
}
.imm-nav {
  white-space: nowrap;
  padding: 18rpx 20rpx;
  border-bottom: 1rpx solid var(--line);
}
.imm-chip {
  display: inline-block;
  margin-right: 14rpx;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: var(--sub);
  background: var(--sky-2);
  max-width: 280rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  vertical-align: middle;
}
.imm-chip-on {
  background: linear-gradient(135deg, #3F57B5, #2B356E);
  color: #fff;
  font-weight: 600;
}
.imm-body { padding: 8rpx 0 12rpx; }
.imm-section { padding: 24rpx 28rpx 8rpx; }
.imm-section + .imm-section {
  border-top: 1rpx dashed var(--line);
  margin-top: 8rpx;
}
.imm-sec-title {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 18rpx;
}
.imm-sec-num {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  background: var(--sky-2);
  color: var(--navy);
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}
.imm-sec-text {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--ink);
  flex: 1;
  min-width: 0;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  line-height: 1.35;
  word-break: break-all;
}
.imm-card { margin-bottom: 22rpx; }
.imm-img {
  height: 320rpx;
  border-radius: 22rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}
.imm-photo { width: 100%; height: 100%; }
.imm-cap {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--sub);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
  word-break: break-all;
}

/* 底部阅读进度 */
.scroll-progress {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: calc(108rpx + env(safe-area-inset-bottom));
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(43, 53, 110, 0.12);
  overflow: visible;
  z-index: 20;
}
.scroll-progress-bar {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #3F57B5, #BE9C44);
  transition: width 0.15s ease;
}
.scroll-progress-text {
  position: absolute;
  right: 0;
  top: -34rpx;
  font-size: 20rpx;
  color: var(--muted);
}
