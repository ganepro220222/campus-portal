/* packageA/news/list.wxss */
.news-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #EAF1FB 0, #F5F8FC 220rpx);
}

/* 分类栏（吸顶） */
.cats {
  position: sticky;
  top: 0;
  z-index: 10;
  white-space: nowrap;
  padding: 16rpx 0;
  background: rgba(245, 248, 252, 0.94);
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  border-bottom: 1rpx solid var(--line);
}
.cats-inner { display: inline-flex; gap: 16rpx; padding: 0 28rpx; }
.cat {
  flex: 0 0 auto;
  font-size: 25rpx;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  background: #fff;
  border: 1rpx solid var(--line);
  color: var(--sub);
}
.cat-on {
  background: linear-gradient(135deg, #3F57B5, #2B356E);
  color: #fff;
  border-color: transparent;
}

/* 列表 */
.news-list { padding: 20rpx 28rpx 0; }
.ncard {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #fff;
  border: 1rpx solid var(--line);
  border-radius: 20rpx;
  padding: 18rpx;
  margin-bottom: 18rpx;
  box-shadow: var(--shadow-sm);
}
.ncard:active { background: var(--sky-3); }
.nthumb {
  flex: 0 0 184rpx;
  height: 132rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
}
.nthumb-img { width: 100%; height: 100%; }
.nbody { flex: 1; min-width: 0; }
.ntitle {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ink);
  line-height: 1.45;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.nmeta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 14rpx;
}
.nmeta-r { display: flex; align-items: center; gap: 14rpx; flex-shrink: 0; }
.nread { display: flex; align-items: center; gap: 5rpx; }
.nread text { font-size: 20rpx; color: var(--muted); }
.ndate { font-size: 21rpx; color: var(--muted); }

.list-tip { text-align: center; color: var(--muted); font-size: 23rpx; padding: 30rpx; }
.list-bottom { height: calc(40rpx + env(safe-area-inset-bottom)); }
