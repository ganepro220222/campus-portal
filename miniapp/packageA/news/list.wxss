/* packageA/news/list.wxss */
.page { background: var(--color-bg); }
.cat-bar { white-space: nowrap; padding: 16rpx 24rpx; background: #fff; border-bottom: 1rpx solid #eee; }
.cat-tag { display: inline-block; padding: 10rpx 28rpx; border-radius: 32rpx; font-size: 26rpx; color: #666; background: #f5f5f5; margin-right: 16rpx; }
.cat-active { background: var(--color-primary); color: #fff; }
.news-card { display: flex; margin: 16rpx 24rpx 0; background: #fff; border-radius: 16rpx; overflow: hidden; }
.news-cover { width: 220rpx; height: 140rpx; flex-shrink: 0; }
.news-info { flex: 1; padding: 16rpx; display: flex; flex-direction: column; justify-content: space-between; }
.news-title { font-size: 28rpx; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
.news-meta { display: flex; justify-content: space-between; font-size: 22rpx; color: #999; }
.no-more { text-align: center; color: #ccc; font-size: 24rpx; padding: 32rpx; }
