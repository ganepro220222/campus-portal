/* packageB/course/detail.wxss */
.detail-page { height: 100vh; display: flex; flex-direction: column; background: #F5F8FC; }
.detail-scroll { flex: 1; overflow: hidden; }
.detail-wrap { padding: 24rpx 28rpx 0; }
.detail-bottom { height: calc(60rpx + env(safe-area-inset-bottom)); }

/* 播放器 */
.player {
  border-radius: 28rpx;
  overflow: hidden;
  background: #0c1024;
  position: relative;
  height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow);
}
.player-bg {
  position: absolute;
  left: 0; top: 0; right: 0; bottom: 0;
  background: linear-gradient(120deg, #1E2654, #3F57B5);
  opacity: 0.85;
}
.play {
  width: 124rpx;
  height: 124rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
  padding-left: 6rpx;
  box-sizing: border-box;
}
.cc {
  position: absolute;
  top: 22rpx; right: 22rpx;
  z-index: 3;
  font-size: 21rpx;
  color: #fff;
  background: rgba(190, 156, 68, 0.9);
  padding: 7rpx 16rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
}
.pbar { position: absolute; left: 26rpx; right: 26rpx; bottom: 24rpx; z-index: 3; }
.ptrack { height: 8rpx; border-radius: 4rpx; background: rgba(255, 255, 255, 0.25); }
.pfill { height: 100%; width: 34%; border-radius: 4rpx; background: var(--gold); }
.ptime {
  display: flex;
  justify-content: space-between;
  font-size: 19rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 10rpx;
}

/* 课程信息 */
.cmeta {
  background: #fff;
  border: 1rpx solid var(--line);
  border-radius: 28rpx;
  padding: 28rpx;
  margin-top: 24rpx;
  box-shadow: var(--shadow-sm);
}
.cmeta-title { font-size: 38rpx; font-weight: 700; color: var(--ink); }
.cmeta-tags { display: flex; gap: 14rpx; margin: 18rpx 0 24rpx; flex-wrap: wrap; }
.minfo { display: grid; grid-template-columns: 1fr 1fr; gap: 18rpx; }
.mi {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
  color: var(--sub);
}
.mi text { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.intro {
  font-size: 26rpx;
  line-height: 1.8;
  color: var(--ink);
  margin-top: 22rpx;
  padding-top: 22rpx;
  border-top: 1rpx dashed var(--line);
}

/* 配套资源 */
.res-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--ink);
  margin: 32rpx 0 18rpx;
  padding-left: 20rpx;
  position: relative;
}
.res-title::before {
  content: "";
  position: absolute;
  left: 0; top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 26rpx;
  border-radius: 3rpx;
  background: linear-gradient(180deg, #3F57B5, #2B356E);
}
.res {
  display: flex;
  align-items: center;
  gap: 22rpx;
  background: #fff;
  border: 1rpx solid var(--line);
  border-radius: 22rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
}
.ft {
  flex: 0 0 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  text-transform: uppercase;
}
.res-info { flex: 1; min-width: 0; }
.res-n { font-size: 26rpx; color: var(--ink); font-weight: 500; }
.res-s { font-size: 21rpx; color: var(--muted); margin-top: 6rpx; }
.res-dl {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: var(--sky-2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.res-dl:active { background: var(--sky); }
