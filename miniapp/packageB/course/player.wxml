// packageB/course/player.wxml — 真视频播放（验收 §2.6）
<view class="player-page">

  <view class="stage">
    <video
      wx:if="{{videoUrl}}"
      id="courseVideo"
      class="course-video"
      src="{{videoUrl}}"
      poster="{{cover}}"
      initial-time="{{initialTime}}"
      direction="90"
      controls
      show-center-play-btn
      enable-play-gesture
      object-fit="contain"
      bindtimeupdate="onTimeUpdate"
      bindended="onEnded"
      bindplay="onPlay"
      bindpause="onPause"
      binderror="onVideoError"
    />
    <view wx:else class="video-empty">
      <text class="video-empty-ic">▶</text>
      <text>课程视频暂未配置</text>
    </view>
    <view wx:if="{{hasSubtitle}}" class="cc-badge {{cc ? 'cc-on' : ''}}" catchtap="onCC">
      <icon name="cc" size="13" color="#ffffff" /> AI 字幕
    </view>
  </view>

  <view wx:if="{{cc && subtitleText}}" class="subtitle">
    <view class="sub-tag"><icon name="cc" size="12" color="#2B356E" /> AI</view>
    <text class="sub-tx">{{subtitleText}}</text>
  </view>

  <scroll-view scroll-y class="player-scroll" enhanced show-scrollbar="{{false}}">
    <view class="now serif">{{course.name}}</view>
    <view class="now-sub">
      {{completed ? '已完成学习' : (progressPercent > 0 ? '已学习 ' + progressPercent + '%' : '开始学习')}}
    </view>
    <view wx:if="{{course.intro}}" class="intro">{{course.intro}}</view>
    <view class="player-bottom"></view>
  </scroll-view>

  <ai-assistant bottom="40" />
</view>
