/* packageB/course/player.wxss */
.player-page { height: 100vh; display: flex; flex-direction: column; background: #F5F8FC; }

/* 播放器舞台 */
.stage {
  position: relative;
  height: 420rpx;
  flex-shrink: 0;
  background: #0c1024;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.stage-bg {
  position: absolute;
  left: 0; top: 0; right: 0; bottom: 0;
  background: linear-gradient(120deg, #1E2654, #3F57B5);
  opacity: 0.85;
}
.cc-badge {
  position: absolute;
  top: 24rpx; right: 24rpx;
  z-index: 3;
  font-size: 21rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.18);
  padding: 8rpx 18rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.28);
}
.cc-badge.cc-on { background: rgba(190, 156, 68, 0.92); border-color: transparent; }
.big-play {
  width: 128rpx; height: 128rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
  padding-left: 6rpx;
  box-sizing: border-box;
}
.big-play:active { transform: scale(0.94); }
.pause-ic { display: flex; gap: 12rpx; padding-left: 0; }
.pause-ic view { width: 14rpx; height: 44rpx; border-radius: 4rpx; background: #2B356E; }
.pbar { position: absolute; left: 28rpx; right: 28rpx; bottom: 26rpx; z-index: 3; }
.ptrack { height: 8rpx; border-radius: 4rpx; background: rgba(255, 255, 255, 0.25); overflow: hidden; }
.pfill { height: 100%; border-radius: 4rpx; background: var(--gold); transition: width 0.3s linear; }
.ptime {
  display: flex;
  justify-content: space-between;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 10rpx;
}

/* AI 字幕条 */
.subtitle {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin: 18rpx 28rpx 0;
  padding: 18rpx 22rpx;
  background: #fff;
  border: 1rpx solid var(--line);
  border-radius: 20rpx;
  box-shadow: var(--shadow-sm);
}
.sub-tag {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: var(--navy);
  background: var(--sky-2);
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
}
.sub-tx { flex: 1; font-size: 24rpx; line-height: 1.6; color: var(--ink); }

/* 列表 */
.player-scroll { flex: 1; overflow: hidden; padding: 0 28rpx; }
.now { font-size: 34rpx; font-weight: 700; color: var(--ink); margin-top: 26rpx; }
.now-sub { font-size: 23rpx; color: var(--muted); margin-top: 8rpx; }

.lessons {
  background: #fff;
  border: 1rpx solid var(--line);
  border-radius: 24rpx;
  padding: 8rpx 24rpx;
  margin-top: 22rpx;
  box-shadow: var(--shadow-sm);
}
.lessons-head { font-size: 28rpx; font-weight: 700; color: var(--ink); padding: 22rpx 0 14rpx; }
.lesson {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 22rpx 12rpx;
  border-top: 1rpx solid var(--line);
  border-radius: 14rpx;
  margin: 0 -12rpx;
}
.lesson-on { background: var(--sky-3); }
.lesson:active { opacity: 0.75; }
.l-idx {
  width: 52rpx; height: 52rpx;
  border-radius: 50%;
  background: var(--sky-2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.lesson-on .l-idx { background: rgba(63, 87, 181, 0.14); }
.l-num { font-size: 26rpx; font-weight: 700; color: var(--navy); }
.eq { display: flex; align-items: flex-end; gap: 4rpx; height: 26rpx; }
.eq-b {
  width: 6rpx;
  height: 10rpx;
  border-radius: 3rpx;
  background: var(--navy);
  animation: eq 0.8s ease-in-out infinite;
}
@keyframes eq { 0%, 100% { height: 8rpx; } 50% { height: 26rpx; } }
.l-body { flex: 1; min-width: 0; }
.l-title {
  font-size: 27rpx;
  color: var(--ink);
  font-weight: 500;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.l-state { font-size: 21rpx; color: var(--muted); margin-top: 6rpx; display: block; }
.lesson-on .l-state { color: var(--navy); font-weight: 600; }
.st-done { color: #3F9A6B; }
.l-dur { font-size: 21rpx; color: var(--muted); flex-shrink: 0; }
.l-go { flex-shrink: 0; }

.player-bottom { height: calc(60rpx + env(safe-area-inset-bottom)); }
