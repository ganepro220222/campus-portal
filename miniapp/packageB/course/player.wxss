/* packageB/course/player.wxss */
.player-page { height: 100vh; display: flex; flex-direction: column; background: #F5F8FC; }

.stage {
  position: relative;
  height: 420rpx;
  flex-shrink: 0;
  background: #0c1024;
  overflow: hidden;
}
.course-video {
  width: 100%;
  height: 100%;
}
.video-empty {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  color: #8A93B2;
  font-size: 26rpx;
}
.video-empty-ic {
  font-size: 48rpx;
  color: #8A93B2;
  line-height: 1;
}
.cc-badge {
  position: absolute;
  top: 24rpx; right: 24rpx;
  z-index: 3;
  font-size: 21rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.18);
  padding: 8rpx 18rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.28);
}
.cc-badge.cc-on { background: rgba(190, 156, 68, 0.92); border-color: transparent; }

.subtitle {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin: 18rpx 28rpx 0;
  padding: 18rpx 22rpx;
  background: #fff;
  border: 1rpx solid var(--line);
  border-radius: 20rpx;
  box-shadow: var(--shadow-sm);
}
.sub-tag {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: var(--navy);
  background: var(--sky-2);
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
}
.sub-tx { flex: 1; font-size: 24rpx; line-height: 1.6; color: var(--ink); }

.player-scroll { flex: 1; overflow: hidden; padding: 0 28rpx; }
.now { font-size: 34rpx; font-weight: 700; color: var(--ink); margin-top: 26rpx; }
.now-sub { font-size: 23rpx; color: var(--muted); margin-top: 8rpx; }
.intro {
  margin-top: 20rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--ink-2);
  background: #fff;
  border: 1rpx solid var(--line);
  border-radius: 20rpx;
  padding: 22rpx;
}
.player-bottom { height: calc(60rpx + env(safe-area-inset-bottom)); }
