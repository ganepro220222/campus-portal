.detail-page {
  min-height: 100vh;
  background: #F5F8FC;
  display: flex;
  flex-direction: column;
}

.detail-scroll {
  flex: 1;
  height: 0;
}

.state-box {
  padding: 120rpx 40rpx;
  text-align: center;
}
.state-text { font-size: 28rpx; color: #8A93B2; }

.hero {
  height: 360rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}
.hero-img { width: 100%; height: 100%; position: absolute; left: 0; top: 0; }
.hero-tag {
  position: absolute;
  left: 24rpx;
  top: 24rpx;
  font-size: 22rpx;
  color: #fff;
  background: rgba(0, 0, 0, 0.28);
  border: 1rpx solid rgba(255, 255, 255, 0.35);
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  z-index: 1;
}

.body {
  margin: -32rpx 24rpx 0;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 32rpx 28rpx 24rpx;
  box-shadow: 0 -4rpx 20rpx rgba(31, 40, 90, 0.06);
  position: relative;
  z-index: 2;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1F2547;
  line-height: 1.45;
  margin-bottom: 20rpx;
}

.meta-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 26rpx;
  color: #5A648A;
  margin-bottom: 12rpx;
}

.quota-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 20rpx 0 12rpx;
}
.quota-chip {
  font-size: 24rpx;
  font-weight: 600;
  color: #2B356E;
  background: #E8F2FB;
  border-radius: 12rpx;
  padding: 8rpx 18rpx;
}
.quota-chip.full { color: #8A93B2; background: #F0F3F8; }
.review-chip {
  font-size: 22rpx;
  color: #BE9C44;
  background: rgba(201, 162, 39, 0.12);
  border-radius: 12rpx;
  padding: 8rpx 16rpx;
}

.enroll-window {
  font-size: 24rpx;
  color: #8A93B2;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.status-banner {
  font-size: 26rpx;
  font-weight: 600;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}
.status-pending { color: #BE9C44; background: rgba(250, 173, 20, 0.12); }
.status-approved { color: #2B356E; background: #E8F2FB; }
.status-rejected { color: #C0392B; background: rgba(192, 57, 43, 0.08); }
.voucher-inline {
  display: block;
  font-size: 24rpx;
  font-weight: 500;
  margin-top: 8rpx;
  color: #5A648A;
}

.section { margin-top: 8rpx; }
.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2B356E;
  margin-bottom: 16rpx;
}
.intro {
  font-size: 28rpx;
  color: #5A648A;
  line-height: 1.75;
  white-space: pre-wrap;
}

.scroll-bottom {
  height: calc(160rpx + env(safe-area-inset-bottom));
}

.foot-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #E7ECF6;
  display: flex;
  gap: 16rpx;
  z-index: 10;
}

.btn-primary,
.btn-outline,
.btn-disabled {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
  margin: 0;
  padding: 0;
}
.btn-primary {
  color: #fff;
  background: linear-gradient(135deg, #3F57B5, #2B356E);
}
.btn-outline {
  color: #2B356E;
  background: #fff;
  border: 2rpx solid #2B356E;
}
.btn-disabled {
  color: #8A93B2;
  background: #F0F3F8;
}
.btn-half { flex: 1; }
