/* packageC/activity/detail.wxss — 高保真视觉 */
.detail-page {
  min-height: 100vh;
  background: #F5F8FC;
  display: flex;
  flex-direction: column;
}

.detail-scroll {
  flex: 1;
  height: 0;
}

.state-box {
  padding: 120rpx 40rpx;
  text-align: center;
}
.state-text { font-size: 28rpx; color: #8A93B2; }

/* 封面 */
.hero {
  height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}
/* 顶部高光 + 底部压暗，让白卡叠加更自然 */
.hero::before {
  content: "";
  position: absolute;
  inset: 0;
  background:
    radial-gradient(120% 80% at 50% 0%, rgba(255, 255, 255, 0.18), transparent 60%),
    linear-gradient(180deg, transparent 55%, rgba(12, 16, 36, 0.32) 100%);
  z-index: 1;
}
.hero-img { width: 100%; height: 100%; position: absolute; left: 0; top: 0; }
.hero-tag {
  position: absolute;
  left: 28rpx;
  top: 28rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #fff;
  background: rgba(12, 16, 36, 0.32);
  border: 1rpx solid rgba(240, 220, 160, 0.6);
  padding: 7rpx 20rpx;
  border-radius: 20rpx;
  z-index: 2;
  backdrop-filter: blur(6rpx);
}

/* 主体卡片 */
.body {
  margin: -40rpx 24rpx 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 34rpx 28rpx 24rpx;
  box-shadow: 0 -6rpx 24rpx rgba(31, 40, 90, 0.08);
  position: relative;
  z-index: 3;
}

.title {
  font-size: 38rpx;
  font-weight: 700;
  color: #1F2547;
  line-height: 1.45;
  margin-bottom: 22rpx;
}

.meta-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #5A648A;
  margin-bottom: 14rpx;
}

.quota-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 24rpx 0 4rpx;
}
.quota-chip {
  font-size: 24rpx;
  font-weight: 600;
  color: #2B356E;
  background: linear-gradient(135deg, #EAF1FB, #E1ECF9);
  border-radius: 14rpx;
  padding: 10rpx 22rpx;
}
.quota-chip.full { color: #8A93B2; background: #F0F3F8; }
.review-chip {
  font-size: 22rpx;
  font-weight: 600;
  color: #9C7C2E;
  background: #FBF3DD;
  border-radius: 14rpx;
  padding: 10rpx 18rpx;
}

.enroll-window {
  font-size: 24rpx;
  color: #8A93B2;
  line-height: 1.5;
  margin: 16rpx 0;
}

.status-banner {
  font-size: 26rpx;
  font-weight: 600;
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  margin: 20rpx 0;
  border-left: 8rpx solid transparent;
}
.status-pending { color: #9C7C2E; background: #FBF3DD; border-left-color: #C9A227; }
.status-approved { color: #2B356E; background: #E8F2FB; border-left-color: #3F57B5; }
.status-rejected { color: #C0392B; background: rgba(192, 57, 43, 0.08); border-left-color: #C0392B; }
.voucher-inline {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  margin-top: 10rpx;
  color: #2B356E;
}

.section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx dashed #E7ECF6;
}
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F2547;
  margin-bottom: 16rpx;
  position: relative;
  padding-left: 20rpx;
}
.section-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 28rpx;
  border-radius: 3rpx;
  background: linear-gradient(180deg, #3F57B5, #2B356E);
}
.intro {
  font-size: 27rpx;
  color: #5A648A;
  line-height: 1.85;
  white-space: pre-wrap;
  text-align: justify;
}

.scroll-bottom {
  height: calc(170rpx + env(safe-area-inset-bottom));
}

/* 底部操作栏 */
.foot-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.97);
  backdrop-filter: blur(16rpx);
  border-top: 1rpx solid #E7ECF6;
  box-shadow: 0 -4rpx 20rpx rgba(31, 40, 90, 0.06);
  display: flex;
  gap: 16rpx;
  z-index: 10;
}

.btn-primary,
.btn-outline,
.btn-disabled {
  flex: 1;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 46rpx;
  font-size: 31rpx;
  font-weight: 700;
  border: none;
  margin: 0;
  padding: 0;
}
.btn-primary::after,
.btn-outline::after,
.btn-disabled::after { border: none; }
.btn-primary {
  color: #fff;
  background: linear-gradient(135deg, #3F57B5, #2B356E);
  box-shadow: 0 12rpx 30rpx rgba(43, 53, 110, 0.32);
}
.btn-outline {
  color: #2B356E;
  background: #fff;
  border: 2rpx solid #2B356E;
}
.btn-disabled {
  color: #8A93B2;
  background: #F0F3F8;
}
.btn-half { flex: 1; }
