<!-- packageC/activity/enroll.wxml — 活动报名 -->
<view class="enroll-page">
  <view wx:if="{{loading}}" class="state-box">
    <text class="state-text">加载中…</text>
  </view>

  <block wx:elif="{{detail}}">
    <scroll-view scroll-y class="enroll-scroll" enhanced show-scrollbar="{{false}}">
      <!-- 活动摘要 -->
      <view class="summary-card">
        <view class="summary-title serif">{{detail.title}}</view>
        <view class="summary-meta">
          <icon name="calendar" size="14" color="#8A93B2" />
          <text>{{detail.startTime}}</text>
        </view>
        <view class="summary-meta">
          <icon name="pin" size="14" color="#8A93B2" />
          <text>{{detail.location}}</text>
        </view>
      </view>

      <!-- 报名成功 -->
      <view wx:if="{{success}}" class="result-card">
        <icon name="medal" size="40" color="#C9A227" />
        <text class="result-title">{{result.statusLabel || '报名成功'}}</text>
        <text wx:if="{{result.voucherCode}}" class="result-code">凭证码：{{result.voucherCode}}</text>
        <text class="result-hint">{{resultHint}}</text>
        <button class="btn-outline" bindtap="onBackDetail">返回活动详情</button>
        <button class="btn-link" bindtap="onMyEnrolls">查看我的报名</button>
      </view>

      <!-- 已有有效报名 -->
      <view wx:elif="{{hasEnrolled}}" class="result-card">
        <text class="result-title">{{statusLabel}}</text>
        <text wx:if="{{detail.voucherCode && detail.enrollStatus === 'approved'}}" class="result-code">凭证码：{{detail.voucherCode}}</text>
        <text class="result-hint">{{enrolledHint}}</text>
        <button class="btn-outline" bindtap="onBackDetail">返回活动详情</button>
      </view>

      <!-- 报名表单 -->
      <view wx:else class="form-card">
        <view class="form-title">填写报名信息</view>
        <view class="form-hint">姓名与手机号为必填；若已在个人资料中完善，可留空由系统自动读取。</view>

        <view class="field">
          <text class="field-label">姓名</text>
          <input
            class="field-input"
            placeholder="请输入真实姓名"
            value="{{form.name}}"
            bindinput="onInput"
            data-field="name"
          />
        </view>
        <view class="field">
          <text class="field-label">手机号</text>
          <input
            class="field-input"
            type="number"
            maxlength="11"
            placeholder="请输入联系电话"
            value="{{form.phone}}"
            bindinput="onInput"
            data-field="phone"
          />
        </view>
        <view class="field">
          <text class="field-label">学院</text>
          <input
            class="field-input"
            placeholder="选填"
            value="{{form.college}}"
            bindinput="onInput"
            data-field="college"
          />
        </view>
        <view class="field">
          <text class="field-label">年级</text>
          <input
            class="field-input"
            placeholder="选填，如 2024 级"
            value="{{form.grade}}"
            bindinput="onInput"
            data-field="grade"
          />
        </view>

        <button class="btn-primary" loading="{{submitting}}" disabled="{{submitting}}" bindtap="onSubmit">
          提交报名
        </button>
      </view>

      <view class="scroll-bottom"></view>
    </scroll-view>
  </block>

  <view wx:else class="state-box">
    <text class="state-text">活动不存在或已下架</text>
  </view>
</view>
