/* packageC/activity/enroll.wxss — 高保真视觉 */
.enroll-page {
  min-height: 100vh;
  background: #F5F8FC;
}

.enroll-scroll {
  height: 100vh;
}

.state-box {
  padding: 120rpx 40rpx;
  text-align: center;
}
.state-text { font-size: 28rpx; color: #8A93B2; }

/* 活动摘要 */
.summary-card {
  margin: 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 28rpx 28rpx 32rpx;
  border: 1rpx solid #E7ECF6;
  box-shadow: 0 8rpx 22rpx rgba(31, 40, 90, 0.06);
  position: relative;
  overflow: hidden;
}
.summary-card::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: linear-gradient(180deg, #CDA94E, #B58A2F);
}
.summary-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1F2547;
  line-height: 1.45;
  margin-bottom: 16rpx;
}
.summary-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 24rpx;
  color: #5A648A;
  margin-bottom: 10rpx;
}

/* 表单 */
.form-card {
  margin: 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx 28rpx 32rpx;
  border: 1rpx solid #E7ECF6;
  box-shadow: 0 8rpx 22rpx rgba(31, 40, 90, 0.06);
}
.form-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F2547;
  margin-bottom: 12rpx;
  position: relative;
  padding-left: 20rpx;
}
.form-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 28rpx;
  border-radius: 3rpx;
  background: linear-gradient(180deg, #3F57B5, #2B356E);
}
.form-hint {
  font-size: 24rpx;
  color: #8A93B2;
  line-height: 1.6;
  margin-bottom: 26rpx;
}

.field { margin-bottom: 24rpx; }
.field-label {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #1F2547;
  margin-bottom: 12rpx;
}
.field-input {
  height: 92rpx;
  padding: 0 26rpx;
  background: #F5F8FC;
  border: 1rpx solid #E7ECF6;
  border-radius: 18rpx;
  font-size: 28rpx;
  color: #1F2547;
  box-sizing: border-box;
}

.btn-primary {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 46rpx;
  font-size: 31rpx;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, #3F57B5, #2B356E);
  border: none;
  margin-top: 12rpx;
  box-shadow: 0 12rpx 30rpx rgba(43, 53, 110, 0.32);
}
.btn-primary::after { border: none; }

/* 报名结果 */
.result-card {
  margin: 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 52rpx 32rpx 40rpx;
  border: 1rpx solid #E7ECF6;
  box-shadow: 0 8rpx 22rpx rgba(31, 40, 90, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}
/* 顶部徽记发光底座 */
.result-card icon:first-child {
  padding: 24rpx;
  border-radius: 50%;
  background: rgba(201, 162, 39, 0.12);
}
.result-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1F2547;
  margin-top: 24rpx;
}
.result-code {
  font-size: 40rpx;
  color: #2B356E;
  font-weight: 700;
  letter-spacing: 4rpx;
  margin-top: 20rpx;
  padding: 16rpx 40rpx;
  background: linear-gradient(135deg, #EAF1FB, #E1ECF9);
  border-radius: 16rpx;
}
.result-hint {
  font-size: 26rpx;
  color: #8A93B2;
  line-height: 1.6;
  margin: 20rpx 0 34rpx;
}

.btn-outline {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #2B356E;
  background: #fff;
  border: 2rpx solid #2B356E;
  margin-bottom: 18rpx;
}
.btn-outline::after { border: none; }
.btn-link {
  font-size: 26rpx;
  color: #3F57B5;
  background: transparent;
  border: none;
  line-height: 1.5;
}
.btn-link::after { border: none; }

.scroll-bottom {
  height: calc(40rpx + env(safe-area-inset-bottom));
}
