.enroll-page {
  min-height: 100vh;
  background: #F5F8FC;
}

.enroll-scroll {
  height: 100vh;
}

.state-box {
  padding: 120rpx 40rpx;
  text-align: center;
}
.state-text { font-size: 28rpx; color: #8A93B2; }

.summary-card,
.form-card,
.result-card {
  margin: 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  border: 1rpx solid #E7ECF6;
  box-shadow: 0 8rpx 22rpx rgba(31, 40, 90, 0.06);
}

.summary-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1F2547;
  line-height: 1.45;
  margin-bottom: 16rpx;
}
.summary-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #5A648A;
  margin-bottom: 8rpx;
}

.form-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2B356E;
  margin-bottom: 12rpx;
}
.form-hint {
  font-size: 24rpx;
  color: #8A93B2;
  line-height: 1.55;
  margin-bottom: 24rpx;
}

.field { margin-bottom: 24rpx; }
.field-label {
  display: block;
  font-size: 26rpx;
  color: #5A648A;
  margin-bottom: 10rpx;
}
.field-input {
  height: 80rpx;
  padding: 0 24rpx;
  background: #F5F8FC;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #1F2547;
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, #3F57B5, #2B356E);
  border: none;
  margin-top: 8rpx;
}

.result-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 48rpx 32rpx;
}
.result-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2B356E;
  margin-top: 20rpx;
}
.result-code {
  font-size: 28rpx;
  color: #BE9C44;
  font-weight: 600;
  margin-top: 16rpx;
}
.result-hint {
  font-size: 26rpx;
  color: #8A93B2;
  line-height: 1.55;
  margin: 16rpx 0 32rpx;
}

.btn-outline {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #2B356E;
  background: #fff;
  border: 2rpx solid #2B356E;
  margin-bottom: 16rpx;
}
.btn-link {
  font-size: 26rpx;
  color: #3F57B5;
  background: transparent;
  border: none;
  line-height: 1.5;
}

.scroll-bottom {
  height: calc(40rpx + env(safe-area-inset-bottom));
}
