<!-- packageC/college/list.wxml -->
<view class="college-page">
  <scroll-view scroll-y class="college-scroll" enhanced show-scrollbar="{{false}}">

    <view class="college-intro">
      <text class="ci-zh serif">关联小程序</text>
      <text class="ci-en">书院兄弟小程序互联入口</text>
    </view>

    <view class="college-grid">
      <view
        wx:for="{{colleges}}"
        wx:key="id"
        class="col-card"
        bindtap="onCardTap"
        data-id="{{item.id}}"
        data-name="{{item.name}}"
      >
        <view class="col-badge {{item.colorClass}}"><text class="cb-tx serif">{{item.short}}</text></view>
        <text class="col-name">{{item.name}}</text>
        <text class="col-en">{{item.en}}</text>
        <text class="col-desc">{{item.desc}}</text>
      </view>
    </view>

    <view class="list-bottom"></view>
  </scroll-view>
</view>
