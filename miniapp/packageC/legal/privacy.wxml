<!-- packageC/legal/privacy.wxml —— 内容由后台「协议内容」配置 -->
<view class="legal-page">
  <nav-bar title="隐私与用户协议" />
  <scroll-view scroll-y class="legal-scroll" enhanced show-scrollbar="{{false}}">

    <view wx:if="{{loading}}" class="legal-loading">加载中…</view>

    <block wx:else>
      <view class="legal-card">
        <view class="legal-title serif">隐私政策</view>
        <rich-text class="legal-rt" nodes="{{privacyHtml}}"></rich-text>
      </view>

      <view class="legal-card">
        <view class="legal-title serif">用户协议</view>
        <rich-text class="legal-rt" nodes="{{agreementHtml}}"></rich-text>
      </view>

      <view class="legal-foot">© 2026 贵州交通职业大学中华文化书院</view>
      <view class="legal-bottom"></view>
    </block>
  </scroll-view>
</view>
