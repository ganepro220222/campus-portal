/* packageC/profile/list.wxss */
.pl-page { min-height: 100vh; background: linear-gradient(180deg, #EAF1FB 0, #F5F8FC 220rpx); }
.pl-state { padding: 100rpx 40rpx; text-align: center; color: var(--muted); font-size: 28rpx; }

.pl-list { padding: 24rpx 28rpx 0; }
.pl-item {
  display: flex;
  align-items: center;
  gap: 22rpx;
  background: #fff;
  border: 1rpx solid var(--line);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
  box-shadow: var(--shadow-sm);
}
.pl-item:active { background: var(--sky-3); }

.pl-ic {
  width: 76rpx;
  height: 76rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 6rpx 16rpx rgba(31, 40, 90, 0.16);
}
.tc-rose { background: linear-gradient(135deg, #C0607A, #8E3B52); }
.tc-blue { background: linear-gradient(135deg, #3F57B5, #2B356E); }
.tc-green { background: linear-gradient(135deg, #3F9A6B, #2E7C55); }
.tc-slate { background: linear-gradient(135deg, #5A6488, #39406A); }
.tc-gold { background: linear-gradient(135deg, #CDA94E, #B58A2F); }
.pl-ic-off { background: #C3CCE0; box-shadow: none; }

.pl-body { flex: 1; min-width: 0; }
.pl-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ink);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.pl-sub {
  font-size: 23rpx;
  color: var(--sub);
  margin-top: 8rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.pl-time { font-size: 21rpx; color: var(--muted); margin-top: 10rpx; display: block; }

.pl-right { flex-shrink: 0; display: flex; align-items: center; }
.pl-status {
  font-size: 21rpx;
  font-weight: 600;
  padding: 8rpx 18rpx;
  border-radius: 20rpx;
}
.st-pending { color: #9C7C2E; background: #FBF3DD; }
.st-approved { color: var(--navy); background: var(--sky-2); }
.st-rejected { color: #C0392B; background: rgba(192, 57, 43, 0.10); }

.pl-badge {
  font-size: 21rpx;
  font-weight: 600;
  padding: 8rpx 18rpx;
  border-radius: 20rpx;
  background: #EEF1F8;
  color: var(--muted);
}
.pl-badge.on { background: rgba(201, 162, 39, 0.15); color: #C9A227; }

.pl-bottom { height: calc(40rpx + env(safe-area-inset-bottom)); }
