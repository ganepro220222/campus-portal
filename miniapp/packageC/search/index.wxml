<!-- packageC/search/index.wxml -->
<view class="search-page">
  <nav-bar title="全局搜索" />

  <!-- 搜索栏 -->
  <view class="sbar">
    <view class="sbox">
      <icon name="search" size="17" color="#8A93B2" />
      <input class="sinput" placeholder="搜索新闻、课程、展馆、资源…" placeholder-class="sph"
        value="{{keyword}}" focus confirm-type="search" bindinput="onInput" bindconfirm="onConfirm" />
      <view wx:if="{{keyword}}" class="sclear" bindtap="onClear"><icon name="eye-off" size="15" color="#8A93B2" /></view>
    </view>
    <view class="sbtn" bindtap="onConfirm">搜索</view>
  </view>

  <scroll-view scroll-y class="search-scroll" enhanced show-scrollbar="{{false}}">

    <!-- 未搜索：热门 + 历史 -->
    <block wx:if="{{!searched}}">
      <view class="sec">
        <view class="sec-h serif">热门搜索</view>
        <view class="tags">
          <view class="tag" wx:for="{{hotTags}}" wx:key="*this" data-k="{{item}}" bindtap="onTag">{{item}}</view>
        </view>
      </view>

      <view class="sec" wx:if="{{history.length}}">
        <view class="sec-h-row">
          <text class="sec-h serif">搜索历史</text>
          <view class="sec-clear" bindtap="clearHistory"><icon name="logout" size="15" color="#8A93B2" /><text>清空</text></view>
        </view>
        <view class="tags">
          <view class="tag tag-ghost" wx:for="{{history}}" wx:key="*this" data-k="{{item}}" bindtap="onTag">{{item}}</view>
        </view>
      </view>
    </block>

    <!-- 搜索结果 -->
    <block wx:else>
      <view class="res-count" wx:if="{{results.length}}">找到 {{results.length}} 条与「{{keyword}}」相关的内容</view>
      <view class="sres" wx:for="{{results}}" wx:key="targetId" data-route="{{item.route}}" bindtap="onResultTap">
        <view class="sres-tag">{{item.typeLabel}}</view>
        <view class="sres-body">
          <text class="sres-title">{{item.title}}</text>
          <text wx:if="{{item.sub}}" class="sres-sub">{{item.sub}}</text>
        </view>
        <icon name="chevron-right" size="16" color="#C3CCE0" />
      </view>

      <view wx:if="{{errorText}}" class="empty-state">
        <icon name="search" size="40" color="#C3CCE0" />
        <text>{{errorText}}</text>
      </view>

      <view wx:elif="{{!results.length}}" class="empty-state">
        <icon name="search" size="40" color="#C3CCE0" />
        <text>未找到「{{keyword}}」相关内容</text>
      </view>
    </block>

    <view class="list-bottom"></view>
  </scroll-view>
</view>
