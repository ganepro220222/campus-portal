/* packageD/ai-chat/index.wxss */
.chat-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #EAF1FB 0, #F5F8FC 320rpx);
}
.chat-body { flex: 1; overflow: hidden; padding: 0 28rpx; }

/* 顶部介绍 */
.chat-intro { display: flex; flex-direction: column; align-items: center; padding: 34rpx 0 28rpx; }
.ci-avatar {
  width: 112rpx; height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #3F57B5, #2B356E);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 30rpx rgba(43, 53, 110, 0.32);
}
.ci-name { font-size: 34rpx; font-weight: 700; color: var(--ink); margin-top: 18rpx; }
.ci-desc { font-size: 22rpx; color: var(--muted); margin-top: 6rpx; }

/* 消息 */
.row { display: flex; align-items: flex-end; gap: 14rpx; margin-bottom: 24rpx; }
.row.me { flex-direction: row-reverse; }
.avt {
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #3F57B5, #2B356E);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.bubble {
  max-width: 74%;
  font-size: 27rpx;
  line-height: 1.7;
  padding: 22rpx 26rpx;
  border-radius: 24rpx;
  word-break: break-word;
}
.bubble.ai {
  background: #fff;
  color: var(--ink);
  border: 1rpx solid var(--line);
  border-bottom-left-radius: 8rpx;
  box-shadow: var(--shadow-sm);
}
.bubble.me {
  background: linear-gradient(135deg, #3F57B5, #2B356E);
  color: #fff;
  border-bottom-right-radius: 8rpx;
  box-shadow: 0 8rpx 20rpx rgba(43, 53, 110, 0.28);
}

/* 快捷问题 */
.chips { display: flex; flex-wrap: wrap; gap: 16rpx; margin: 4rpx 0 10rpx 70rpx; }
.chip {
  font-size: 24rpx;
  color: var(--navy);
  background: #fff;
  border: 1rpx solid var(--sky);
  padding: 14rpx 24rpx;
  border-radius: 30rpx;
  box-shadow: var(--shadow-sm);
}
.chip:active { background: var(--sky-2); }
.chat-pad { height: 20rpx; }

/* 输入区 */
.chat-input {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 28rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.97);
  backdrop-filter: blur(16rpx);
  border-top: 1rpx solid var(--line);
}
.ci-in {
  flex: 1;
  height: 76rpx;
  background: var(--sky-3);
  border: 1rpx solid var(--line);
  border-radius: 38rpx;
  padding: 0 26rpx;
  font-size: 27rpx;
  color: var(--ink);
}
.ci-ph { color: var(--muted); }
.send {
  width: 76rpx; height: 76rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #3F57B5, #2B356E);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 8rpx 20rpx rgba(43, 53, 110, 0.3);
}
.send:active { opacity: 0.85; }
