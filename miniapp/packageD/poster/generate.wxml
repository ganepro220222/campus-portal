<!-- packageD/poster/generate.wxml -->
<view class="poster-page">
  <nav-bar title="生成海报" />
  <scroll-view scroll-y class="poster-scroll" enhanced show-scrollbar="{{false}}">

    <!-- 预览 -->
    <view class="preview">
      <view class="poster" style="background: linear-gradient(160deg, {{tpl.c1}}, {{tpl.c2}});">
        <view class="p-frame" style="border-color: {{tpl.accent}};"></view>
        <view class="p-top">中 华 文 化 书 院</view>
        <view class="p-seal" style="box-shadow: 0 0 0 2rpx {{tpl.accent}};">
          <image class="p-seal-img" src="/assets/images/school-badge.png" mode="aspectFit" />
        </view>
        <view class="p-title serif">{{title}}</view>
        <view class="p-div">
          <view class="p-line" style="background: linear-gradient(90deg, transparent, {{tpl.accent}}, transparent);"></view>
          <text class="p-orn" style="color: {{tpl.accent}};">❖</text>
        </view>
        <view class="p-sub">{{subtitle}}</view>
        <view class="p-foot">
          <view class="p-qr">
            <view class="qr-c qr-tl"></view>
            <view class="qr-c qr-tr"></view>
            <view class="qr-c qr-bl"></view>
            <view class="qr-mid" style="background: {{tpl.accent}};"></view>
          </view>
          <view class="p-foot-tx">
            <text class="pf-1">长按识别小程序码</text>
            <text class="pf-2">云端书院 · 传承中华文化</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 模板 -->
    <view class="tpl-title serif">选择模板风格</view>
    <view class="tpls">
      <view
        wx:for="{{templates}}"
        wx:key="key"
        class="tpl {{active === index ? 'tpl-on' : ''}}"
        data-i="{{index}}"
        bindtap="onPick"
      >
        <view class="tpl-sw" style="background: linear-gradient(160deg, {{item.c1}}, {{item.c2}});">
          <view wx:if="{{active === index}}" class="tpl-check"><icon name="thumb" size="14" color="#ffffff" /></view>
        </view>
        <text class="tpl-name">{{item.name}}</text>
      </view>
    </view>

    <view class="poster-tip">
      <icon name="star" size="14" color="#BE9C44" />
      <text>海报将保存为图片到手机相册，可分享至微信、朋友圈</text>
    </view>

    <view class="poster-bottom"></view>
  </scroll-view>

  <!-- 保存 -->
  <view class="save-bar">
    <button class="save-btn {{saving ? 'saving' : ''}}" bindtap="onSave" disabled="{{saving}}">
      <icon name="download" size="18" color="#ffffff" />
      <text>{{saving ? '生成中…' : '保存到相册'}}</text>
    </button>
  </view>

  <!-- 离屏画布 -->
  <canvas type="2d" id="posterCanvas" class="hidden-canvas"></canvas>
</view>
