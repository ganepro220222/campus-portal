/* pages/activity/index.wxss — 活动列表页 */

.page { background: #F5F8FC; min-height: 100vh; padding-top: 16rpx; }

.activity-card {
  margin: 0 32rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid #E7ECF6;
  box-shadow: 0 6rpx 20rpx rgba(31,40,90,.08);
}
.activity-card:active { opacity: .95; }
.activity-cover {
  width: 100%; height: 240rpx;
  background: linear-gradient(135deg, #1B2A4A, #2E5C7A);
  display: block;
}
.activity-info { padding: 24rpx 28rpx; }
.activity-title {
  display: block;
  font-size: 30rpx; font-weight: 700;
  color: #1F2547;
  font-family: "Noto Serif SC", serif;
  margin-bottom: 14rpx;
}
.activity-time {
  display: flex; align-items: center; gap: 8rpx;
  font-size: 24rpx; color: #5A648A;
  margin-bottom: 8rpx;
}
.activity-location {
  display: flex; align-items: center; gap: 8rpx;
  font-size: 24rpx; color: #5A648A;
  margin-bottom: 14rpx;
}
.activity-quota {
  display: inline-block;
  font-size: 22rpx;
  color: #2B356E;
  background: #E8F2FB;
  border-radius: 12rpx;
  padding: 6rpx 18rpx;
  font-weight: 600;
}
.quota-full {
  color: #8A93B2;
  background: #F5F8FC;
}
