/* pages/activity/index.wxss — 活动报名（二级页）*/
.act-page { min-height: 100vh; background: #F5F8FC; }
.act-wrap { padding: 24rpx 32rpx; }

.acard {
  display: flex;
  gap: 22rpx;
  background: #fff;
  border-radius: 26rpx;
  border: 1rpx solid #E7ECF6;
  box-shadow: 0 8rpx 22rpx rgba(31, 40, 90, 0.09);
  padding: 20rpx;
  margin-bottom: 22rpx;
  transition: transform 0.15s;
}
.acard:active { transform: scale(0.99); }
.acard-cover {
  position: relative;
  flex: 0 0 180rpx;
  height: 180rpx;
  border-radius: 20rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}
.acard-img { width: 100%; height: 100%; }
.acard-tag {
  position: absolute;
  left: 12rpx;
  top: 12rpx;
  font-size: 19rpx;
  color: #fff;
  background: rgba(0, 0, 0, 0.28);
  border: 1rpx solid rgba(255, 255, 255, 0.35);
  padding: 3rpx 12rpx;
  border-radius: 14rpx;
}
.acard-body { flex: 1; min-width: 0; display: flex; flex-direction: column; }
.acard-title {
  font-size: 29rpx;
  font-weight: 700;
  color: #1F2547;
  line-height: 1.4;
  font-family: "Noto Serif SC", serif;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.acard-meta { display: flex; align-items: center; gap: 8rpx; margin-top: 10rpx; }
.acard-mt {
  font-size: 22rpx;
  color: #5A648A;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.acard-foot {
  margin-top: auto;
  padding-top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.quota {
  font-size: 21rpx;
  color: #2B356E;
  background: #E8F2FB;
  border-radius: 12rpx;
  padding: 6rpx 16rpx;
  font-weight: 600;
}
.quota-full { color: #8A93B2; background: #F0F3F8; }
.enroll-btn {
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, #3F57B5, #2B356E);
  border-radius: 30rpx;
  padding: 10rpx 30rpx;
}
.enroll-off { background: #C3CCE0; }

.safe-bottom { height: calc(40rpx + env(safe-area-inset-bottom)); }
