<!-- pages/course/index.wxml -->
<view class="page">
  <scroll-view scroll-x class="cat-bar">
    <view wx:for="{{categories}}" wx:key="id" class="cat-tag {{currentCat===item.id?'cat-active':''}}" bindtap="switchCat" data-id="{{item.id}}">{{item.name}}</view>
  </scroll-view>
  <view wx:for="{{courseList}}" wx:key="id" class="course-card" bindtap="onCardTap" data-id="{{item.id}}">
    <image class="course-cover" src="{{item.cover}}" mode="aspectFill" lazy-load />
    <view class="course-info">
      <text class="course-name">{{item.name}}</text>
      <text class="course-meta">{{item.durationMinutes ? item.durationMinutes + '分钟' : ''}}  {{item.targetAudience}}</text>
    </view>
  </view>
  <view wx:if="{{!loading && !courseList.length}}" class="empty-state"><text>暂无课程</text></view>
  <view class="safe-bottom" />
</view>
