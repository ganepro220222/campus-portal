/* pages/course/index.wxss — 课程列表页 */

.page { background: #F5F8FC; min-height: 100vh; }

.cat-bar {
  white-space: nowrap;
  padding: 20rpx 32rpx 16rpx;
  background: #fff;
  border-bottom: 1rpx solid #E7ECF6;
}
.cat-tag {
  display: inline-block;
  padding: 12rpx 32rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  color: #5A648A;
  background: #fff;
  border: 1rpx solid #E7ECF6;
  margin-right: 16rpx;
}
.cat-active {
  background: linear-gradient(135deg, #3F57B5, #2B356E);
  color: #fff;
  border-color: transparent;
}

.course-card {
  margin: 24rpx 32rpx 0;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid #E7ECF6;
  box-shadow: 0 6rpx 20rpx rgba(31,40,90,.08);
}
.course-card:active { opacity: .95; }
.course-cover {
  width: 100%; height: 260rpx;
  background: linear-gradient(135deg, #1E2654, #3F57B5);
  display: block;
}
.course-info { padding: 24rpx 28rpx; }
.course-name {
  display: block;
  font-size: 30rpx; font-weight: 700;
  color: #1F2547;
  font-family: "Noto Serif SC", serif;
}
.course-meta {
  display: block;
  font-size: 22rpx; color: #8A93B2;
  margin-top: 10rpx;
}

.loading-tip {
  text-align: center; color: #8A93B2;
  padding: 80rpx; font-size: 26rpx;
}
