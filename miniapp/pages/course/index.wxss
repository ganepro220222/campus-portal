/* pages/course/index.wxss */
.course-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #EAF1FB 0, #F5F8FC 240rpx);
}

/* 顶栏 */
.nav {
  flex: 0 0 auto;
  position: relative;
  z-index: 10;
  background: rgba(255, 255, 255, 0.94);
  backdrop-filter: blur(20rpx);
  border-bottom: 1rpx solid var(--line);
  box-shadow: 0 2rpx 14rpx rgba(31, 40, 90, 0.05);
}
.nav-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  min-height: 80rpx; /* 无 navContentHeight 时的回退，实际高度由 JS 按胶囊几何注入 */
  padding: 0 0 0 32rpx;
}
.nav-title { font-size: 38rpx; font-weight: 700; color: var(--ink); }
.nav-search {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
}
.nav-search:active { background: var(--sky-3); }

.cats { white-space: nowrap; padding: 6rpx 0 18rpx; }
.cats-inner { display: inline-flex; gap: 16rpx; padding: 0 32rpx; }
.cat {
  flex: 0 0 auto;
  font-size: 25rpx;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  background: #fff;
  border: 1rpx solid var(--line);
  color: var(--sub);
  transition: 0.15s;
}
.cat-on {
  background: linear-gradient(135deg, #3F57B5, #2B356E);
  color: #fff;
  border-color: transparent;
}

/* 列表 */
.course-scroll { flex: 1; overflow: hidden; }
.course-wrap { padding: 24rpx 32rpx 0; }

.ccard {
  display: flex;
  gap: 24rpx;
  background: #fff;
  border: 1rpx solid var(--line);
  border-radius: 28rpx;
  padding: 22rpx;
  box-shadow: var(--shadow-sm);
  margin-bottom: 22rpx;
  transition: transform 0.15s;
}
.ccard:active { transform: scale(0.99); }
.ccard-thumb {
  flex: 0 0 168rpx;
  height: 168rpx;
  border-radius: 20rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}
.ccard-img { width: 100%; height: 100%; }
.ccard-body { flex: 1; min-width: 0; display: flex; flex-direction: column; }
.ccard-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--ink);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  line-height: 1.4;
  word-break: break-all;
}
.ccard-desc {
  font-size: 24rpx;
  color: var(--sub);
  line-height: 1.55;
  margin-top: 10rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.ccard-meta {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: auto;
  padding-top: 14rpx;
  flex-wrap: wrap;
}
.meta-i { display: flex; align-items: center; gap: 6rpx; font-size: 22rpx; color: var(--muted); }

.list-bottom { height: calc(150rpx + env(safe-area-inset-bottom)); }
