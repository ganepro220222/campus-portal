<!-- pages/hall/index.wxml -->
<view class="hall-page">

  <!-- 自定义顶栏 -->
  <view class="nav">
    <view style="height: {{statusBarHeight}}px;"></view>
    <view class="nav-row" style="padding-right: {{capsulePadding}}px;">
      <text class="nav-title serif">线上展馆</text>
      <view class="nav-search" bindtap="onSearch">
        <icon name="search" size="20" color="#1F2547" />
      </view>
    </view>
    <scroll-view scroll-x class="cats" enhanced show-scrollbar="{{false}}">
      <view class="cats-inner">
        <view
          wx:for="{{cats}}"
          wx:key="*this"
          class="cat {{activeCat === index ? 'cat-on' : ''}}"
          data-index="{{index}}"
          bindtap="switchCat"
        >{{item}}</view>
      </view>
    </scroll-view>
  </view>

  <!-- 展馆网格 -->
  <scroll-view scroll-y class="hall-scroll" enhanced show-scrollbar="{{false}}">
    <view class="hall-grid">
      <view
        wx:for="{{hallList}}"
        wx:key="id"
        class="hcard"
        bindtap="onCardTap"
        data-id="{{item.id}}"
      >
        <view class="hcard-cover {{item.colorClass}}">
          <view wx:if="{{item.cover}}" class="hcard-bg">
            <image src="{{item.cover}}" mode="aspectFill" class="hcard-img" />
          </view>
          <view class="hcard-corner"><icon name="museum" size="40" color="rgba(255,255,255,0.32)" /></view>
          <text class="hcard-ct serif">{{item.shortName}}</text>
        </view>
        <view class="hcard-foot">
          <text class="hcard-name">{{item.name}}</text>
          <text class="hcard-desc">{{item.desc}}</text>
          <text class="hcard-vr {{item.vrReady ? '' : 'hcard-vr-off'}}">{{item.vrReady ? 'VR 可体验' : 'VR 筹备中'}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{!loading && !hallList.length}}" class="empty-state">
      <icon name="museum" size="40" color="#C3CCE0" />
      <text>暂无展馆内容</text>
    </view>

    <view class="list-bottom"></view>
  </scroll-view>

</view>
