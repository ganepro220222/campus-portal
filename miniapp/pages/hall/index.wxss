/* pages/hall/index.wxss */
.hall-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #EAF1FB 0, #F5F8FC 240rpx);
}

/* 顶栏 */
.nav {
  flex: 0 0 auto;
  position: relative;
  z-index: 10;
  background: rgba(255, 255, 255, 0.94);
  backdrop-filter: blur(20rpx);
  border-bottom: 1rpx solid var(--line);
  box-shadow: 0 2rpx 14rpx rgba(31, 40, 90, 0.05);
}
.nav-row {
  display: flex;
  align-items: center;
  height: 80rpx;
  padding: 6rpx 32rpx 4rpx;
}
.nav-title { font-size: 38rpx; font-weight: 700; color: var(--ink); }

.cats { white-space: nowrap; padding: 6rpx 0 18rpx; }
.cats-inner { display: inline-flex; gap: 16rpx; padding: 0 32rpx; }
.cat {
  flex: 0 0 auto;
  font-size: 25rpx;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  background: #fff;
  border: 1rpx solid var(--line);
  color: var(--sub);
}
.cat-on {
  background: linear-gradient(135deg, #3F57B5, #2B356E);
  color: #fff;
  border-color: transparent;
}

/* 网格 */
.hall-scroll { flex: 1; overflow: hidden; }
.hall-grid {
  padding: 24rpx 32rpx 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}
.hcard {
  border-radius: 26rpx;
  overflow: hidden;
  background: #fff;
  border: 1rpx solid var(--line);
  box-shadow: 0 8rpx 22rpx rgba(31, 40, 90, 0.10);
  transition: transform 0.15s;
}
.hcard:active { transform: translateY(-4rpx); }
.hcard-cover {
  position: relative;
  height: 180rpx;
  padding: 20rpx;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
}
.hcard-bg { position: absolute; left: 0; top: 0; right: 0; bottom: 0; }
.hcard-img { width: 100%; height: 100%; opacity: 0.4; }
.hcard-corner { position: absolute; right: 16rpx; top: 14rpx; }
.hcard-ct {
  position: relative;
  z-index: 2;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.3);
}
.hcard-foot { padding: 16rpx 20rpx 20rpx; }
.hcard-name { font-size: 27rpx; font-weight: 600; color: var(--ink); display: block; }
.hcard-desc {
  font-size: 21rpx;
  color: var(--muted);
  margin-top: 6rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.list-bottom { height: calc(150rpx + env(safe-area-inset-bottom)); }
