/* pages/hall/index.wxss — 展馆列表页 */

.page { background: #F5F8FC; min-height: 100vh; }

/* 分类横滑 */
.cat-bar {
  white-space: nowrap;
  padding: 20rpx 32rpx 16rpx;
  background: #fff;
  border-bottom: 1rpx solid #E7ECF6;
  box-shadow: 0 2rpx 10rpx rgba(31,40,90,.04);
}
.cat-tag {
  display: inline-block;
  padding: 12rpx 32rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  color: #5A648A;
  background: #fff;
  border: 1rpx solid #E7ECF6;
  margin-right: 16rpx;
}
.cat-active {
  background: linear-gradient(135deg, #3F57B5, #2B356E);
  color: #fff;
  border-color: transparent;
}

/* 展馆卡片（大图模式）*/
.hall-card {
  margin: 24rpx 32rpx 0;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid #E7ECF6;
  box-shadow: 0 6rpx 20rpx rgba(31,40,90,.09);
}
.hall-card:active { opacity: .95; }

.hall-cover {
  width: 100%;
  height: 280rpx;
  background: linear-gradient(135deg, #2B356E, #475BA6);
  display: block;
}

.hall-info { padding: 24rpx 28rpx; }
.hall-name {
  display: block;
  font-size: 32rpx; font-weight: 700;
  color: #1F2547;
  font-family: "Noto Serif SC", serif;
}
.hall-intro {
  display: block;
  font-size: 24rpx; color: #8A93B2;
  margin-top: 10rpx;
  overflow: hidden; text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: 1.6;
}

.loading-tip {
  text-align: center; color: #8A93B2;
  padding: 80rpx; font-size: 26rpx;
}
