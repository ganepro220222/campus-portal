<!-- pages/index/index.wxml -->
<view class="home-page">

  <!-- 吸顶 Header：校名 + 铃铛（状态栏占位 + 内容区）-->
  <view class="header">
    <view style="height: {{statusBarHeight}}px;"></view>
    <view class="header-row">
      <image class="school-title-img" src="/assets/images/school-title.png" mode="heightFix" />
      <view class="bell-btn" bindtap="onBellTap">
        <view class="bell-icon">
          <text class="bell-svg">🔔</text>
        </view>
        <view wx:if="{{hasNewAnnouncement}}" class="bell-dot"></view>
      </view>
    </view>
    <!-- 搜索框 -->
    <view class="search-bar" bindtap="onSearchTap">
      <view class="search-icon-wrap">
        <text class="s-icon">🔍</text>
      </view>
      <text class="search-placeholder">搜索新闻、展馆、课程…</text>
    </view>
  </view>

  <scroll-view class="scroll-body" scroll-y enhanced>

    <!-- Banner 轮播 -->
    <view class="wrap">
      <swiper
        class="banner"
        autoplay
        interval="4200"
        circular
        indicator-dots="{{false}}"
        bindchange="onBannerChange"
      >
        <swiper-item
          wx:for="{{banners}}"
          wx:key="id"
          bindtap="onBannerTap"
          data-link-type="{{item.linkType}}"
          data-link-value="{{item.linkValue}}"
        >
          <!-- 有图片用图片，无图片用渐变占位 -->
          <view class="bslide {{item.colorClass || 's1'}}">
            <view class="bslide-deco"></view>
            <view wx:if="{{item.imageUrl}}" class="bslide-bg">
              <image src="{{item.imageUrl}}" mode="aspectFill" class="bslide-img" />
            </view>
            <view class="bslide-tag">
              <text>{{item.category || '书院动态'}}</text>
            </view>
            <view class="bslide-title serif">{{item.title}}</view>
            <view class="bslide-desc">{{item.description}}</view>
          </view>
        </swiper-item>
      </swiper>
      <!-- 自定义指示点 -->
      <view class="bdots">
        <view
          wx:for="{{banners}}"
          wx:key="id"
          class="bdot {{bannerIndex === index ? 'bdot-on' : ''}}"
        ></view>
      </view>

      <!-- 公告条 -->
      <view wx:if="{{announcements.length}}" class="notice-bar" bindtap="onNoticeTap">
        <text class="notice-ic">📢</text>
        <text class="notice-text">{{announcements[0].content}}</text>
        <text class="notice-arrow">›</text>
      </view>
    </view>

    <!-- 功能入口矩阵 -->
    <view class="entries-wrap wrap">
      <view class="entries">
        <view class="entry" bindtap="onNavTap" data-path="/pages/hall/index">
          <view class="ico ico-1">
            <view class="ico-symbol">馆</view>
          </view>
          <text class="entry-label">展馆展示</text>
        </view>
        <view class="entry" bindtap="onNavTap" data-path="/pages/course/index">
          <view class="ico ico-2">
            <view class="ico-symbol">课</view>
          </view>
          <text class="entry-label">课程中心</text>
        </view>
        <view class="entry" bindtap="onNavTap" data-path="/pages/activity/index">
          <view class="ico ico-5">
            <view class="ico-symbol">活</view>
          </view>
          <text class="entry-label">活动报名</text>
        </view>
        <view class="entry" bindtap="onNavTap" data-path="/packageB/resource/list">
          <view class="ico ico-3">
            <view class="ico-symbol">资</view>
          </view>
          <text class="entry-label">资源下载</text>
        </view>
        <view class="entry" bindtap="onNavTap" data-path="/packageC/search/index">
          <view class="ico ico-4">
            <view class="ico-symbol">搜</view>
          </view>
          <text class="entry-label">全站搜索</text>
        </view>
      </view>
    </view>

    <!-- 展馆横滑 -->
    <view class="section wrap">
      <view class="sec-head">
        <view class="sec-title serif">线上展馆</view>
        <navigator url="/pages/hall/index" hover-class="none" class="sec-more">更多 ›</navigator>
      </view>
      <scroll-view scroll-x class="halls-scroll" enhanced show-scrollbar="{{false}}">
        <view class="halls-inner">
          <view
            wx:for="{{hallList}}"
            wx:key="id"
            class="hall-card {{item.colorClass || 'hc1'}}"
            bindtap="onHallTap"
            data-id="{{item.id}}"
          >
            <view wx:if="{{item.cover}}" class="hc-bg">
              <image src="{{item.cover}}" mode="aspectFill" class="hc-img" />
            </view>
            <view class="hc-mask"></view>
            <view class="hc-name serif">{{item.name}}</view>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 最新资讯 -->
    <view class="section wrap">
      <view class="sec-head">
        <view class="sec-title serif">最新资讯</view>
        <navigator url="/packageA/news/list" hover-class="none" class="sec-more">更多 ›</navigator>
      </view>
      <view class="cards">
        <view
          wx:for="{{newsList}}"
          wx:key="id"
          class="ncard"
          bindtap="onNewsCardTap"
          data-id="{{item.id}}"
        >
          <view class="ncard-thumb {{item.colorClass || 'hc1'}}">
            <image wx:if="{{item.cover}}" src="{{item.cover}}" mode="aspectFill" class="ncard-img" />
          </view>
          <view class="ncard-body">
            <view class="ncard-title">{{item.title}}</view>
            <view class="ncard-meta">
              <view class="pill">{{item.categoryName || '书院动态'}}</view>
              <text class="ncard-date">{{item.publishTime}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 热门课程 -->
    <view class="section wrap">
      <view class="sec-head">
        <view class="sec-title serif">热门课程</view>
        <navigator url="/pages/course/index" hover-class="none" class="sec-more">更多 ›</navigator>
      </view>
      <view class="cards">
        <view
          wx:for="{{courseList}}"
          wx:key="id"
          class="ccard"
          bindtap="onCourseCardTap"
          data-id="{{item.id}}"
        >
          <view class="ccard-thumb {{item.colorClass || 'hc3'}}">
            <image wx:if="{{item.cover}}" src="{{item.cover}}" mode="aspectFill" class="ccard-img" />
          </view>
          <view class="ccard-body">
            <view class="ccard-title">{{item.name}}</view>
            <view class="ccard-meta">
              <view class="pill gold">{{item.categoryName || '文化课程'}}</view>
              <text class="ccard-sub">{{item.lessonCount || 0}} 课时</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view style="height: 40rpx;"></view>
  </scroll-view>

</view>
