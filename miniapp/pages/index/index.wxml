<!-- pages/index/index.wxml -->
<view class="home-page">

  <!-- 吸顶 Header：校名居中 + （我的 · 搜索 · 铃铛）一行 -->
  <view class="header">
    <view style="height: {{statusBarHeight}}px;"></view>
    <!-- 校名（书法字·图片，跨机型显示一致；高度随胶囊几何对齐） -->
    <view class="header-titlebar" style="height: {{navContentHeight}}px;">
      <image class="header-name-img" src="/assets/images/home-title-calligraphy.png" mode="heightFix" />
    </view>
    <!-- 我的 + 搜索 + 铃铛（同一行，一左一右） -->
    <view class="header-actionbar">
      <view class="header-icon" bindtap="onProfileTap">
        <icon name="user-circle" size="24" color="#2B356E" />
      </view>
      <view class="search-bar" bindtap="onSearchTap">
        <icon name="search" size="17" color="#8A93B2" />
        <text class="search-placeholder">搜索新闻、课程、展馆、资源…</text>
      </view>
      <view class="header-icon" bindtap="onBellTap">
        <icon name="bell" size="22" color="#2B356E" />
        <view wx:if="{{hasNewAnnouncement}}" class="bell-dot"></view>
      </view>
    </view>
  </view>

  <scroll-view class="scroll-body" scroll-y enhanced show-scrollbar="{{false}}">

    <skeleton show="{{loading}}" type="home" count="5" />
    <block wx:if="{{!loading}}">

    <!-- Banner 轮播 -->
    <view class="wrap">
      <swiper
        class="banner"
        autoplay
        interval="4200"
        circular
        indicator-dots="{{false}}"
        bindchange="onBannerChange"
      >
        <swiper-item
          wx:for="{{banners}}"
          wx:key="id"
          bindtap="onBannerTap"
          data-link-type="{{item.linkType}}"
          data-link-value="{{item.linkValue}}"
        >
          <view class="bslide {{item.colorClass || 's1'}}">
            <view class="bslide-deco"></view>
            <view wx:if="{{item.imageUrl}}" class="bslide-bg">
              <image src="{{item.imageUrl}}" mode="{{item.coverImageMode || 'aspectFill'}}" class="bslide-img" />
            </view>
            <view class="bslide-tag">{{item.category || '书院动态'}}</view>
            <view class="bslide-title serif">{{item.title}}</view>
            <view class="bslide-desc">{{item.description}}</view>
          </view>
        </swiper-item>
      </swiper>
      <view class="bdots">
        <view
          wx:for="{{banners}}"
          wx:key="id"
          class="bdot {{bannerIndex === index ? 'bdot-on' : ''}}"
        ></view>
      </view>

      <!-- 公告条 -->
      <view wx:if="{{announcements.length}}" class="notice-bar" bindtap="onNoticeTap">
        <icon name="megaphone" size="16" color="#BE9C44" />
        <text class="notice-text">{{announcements[0].content}}</text>
        <icon name="chevron-right" size="15" color="#8A93B2" />
      </view>
    </view>

    <!-- 功能入口矩阵 -->
    <view class="entries-wrap wrap">
      <view class="entries">
        <view class="entry" bindtap="onEntryTap" data-key="news">
          <view class="ico e1"><icon name="entry-news" size="25" color="#ffffff" /></view>
          <text class="entry-label">新闻资讯</text>
        </view>
        <view class="entry" bindtap="onEntryTap" data-key="hall">
          <view class="ico e2"><icon name="museum" size="25" color="#ffffff" /></view>
          <text class="entry-label">展馆展示</text>
        </view>
        <view class="entry" bindtap="onEntryTap" data-key="course">
          <view class="ico e3"><icon name="course" size="25" color="#ffffff" /></view>
          <text class="entry-label">课程中心</text>
        </view>
        <view class="entry" bindtap="onEntryTap" data-key="resource">
          <view class="ico e4"><icon name="entry-resource" size="25" color="#ffffff" /></view>
          <text class="entry-label">资源下载</text>
        </view>
        <view class="entry" bindtap="onEntryTap" data-key="enroll">
          <view class="ico e5"><icon name="entry-enroll" size="25" color="#ffffff" /></view>
          <text class="entry-label">报名</text>
        </view>
      </view>
    </view>

    <!-- 文化好物（工艺品展示，无在线购买） -->
    <view class="craft-banner wrap" bindtap="onCraftTap">
      <view class="craft-banner-inner">
        <view class="craft-ic"><icon name="medal" size="28" color="#ffffff" /></view>
        <view class="craft-text">
          <text class="craft-title serif">非遗文化好物</text>
          <text class="craft-sub">工艺品鉴赏 · 咨询选购</text>
        </view>
        <icon name="chevron-right" size="18" color="rgba(255,255,255,0.85)" />
      </view>
    </view>

    <!-- 线上展馆 -->
    <view class="section wrap">
      <view class="sec-head">
        <view class="sec-title serif">线上展馆 · 11 馆</view>
        <view class="sec-more" bindtap="onEntryTap" data-key="hall">全部<icon name="chevron-right" size="13" color="#8A93B2" /></view>
      </view>
      <scroll-view scroll-x class="halls-scroll" enhanced show-scrollbar="{{false}}">
        <view class="halls-inner">
          <view
            wx:for="{{hallList}}"
            wx:key="id"
            class="hall-card"
            bindtap="onHallTap"
            data-id="{{item.id}}"
          >
            <view class="hc-cover {{item.colorClass || 'hc1'}}">
              <view wx:if="{{item.cover}}" class="hc-bg">
                <image src="{{item.cover}}" mode="{{item.coverImageMode || 'aspectFill'}}" class="hc-img" />
              </view>
              <view class="hc-corner"><icon name="museum" size="30" color="rgba(255,255,255,0.34)" /></view>
              <text class="hc-ct serif">{{item.shortName}}</text>
            </view>
            <view class="hc-name">{{item.name}}</view>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 最新资讯 -->
    <view class="section wrap">
      <view class="sec-head">
        <view class="sec-title serif">最新资讯</view>
        <view class="sec-more" bindtap="onEntryTap" data-key="news">更多<icon name="chevron-right" size="13" color="#8A93B2" /></view>
      </view>
      <view class="cards">
        <view
          wx:for="{{newsList}}"
          wx:key="id"
          class="ncard"
          bindtap="onNewsCardTap"
          data-id="{{item.id}}"
        >
          <view class="ncard-thumb {{item.colorClass || 'hc1'}}">
            <image wx:if="{{item.cover}}" src="{{item.cover}}" mode="{{item.coverImageMode || 'aspectFill'}}" class="ncard-img" />
            <icon wx:else name="{{item.icon}}" size="26" color="rgba(255,255,255,0.92)" />
          </view>
          <view class="ncard-body">
            <view class="ncard-title">{{item.title}}</view>
            <view class="ncard-meta">
              <text class="pill">{{item.categoryName}}</text>
              <text class="ncard-date">{{item.publishTime}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 热门课程 -->
    <view class="section wrap">
      <view class="sec-head">
        <view class="sec-title serif">热门课程</view>
        <view class="sec-more" bindtap="onEntryTap" data-key="course">更多<icon name="chevron-right" size="13" color="#8A93B2" /></view>
      </view>
      <view class="cards">
        <view
          wx:for="{{courseList}}"
          wx:key="id"
          class="ccard"
          bindtap="onCourseCardTap"
          data-id="{{item.id}}"
        >
          <view class="ccard-thumb {{item.colorClass || 'hc3'}}">
            <image wx:if="{{item.cover}}" src="{{item.cover}}" mode="{{item.coverImageMode || 'aspectFill'}}" class="ccard-img" />
            <icon wx:else name="{{item.icon}}" size="30" color="rgba(255,255,255,0.92)" />
          </view>
          <view class="ccard-body">
            <view class="ccard-title serif">{{item.name}}</view>
            <view class="ccard-meta">
              <text class="pill {{item.categoryName === 'AI 字幕' ? 'gold' : ''}}">{{item.categoryName}}</text>
              <text class="ccard-sub">{{item.lessonCount || 0}} 课时</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="scroll-bottom"></view>
    </block>
  </scroll-view>

  <!-- AI 助手 -->
  <ai-assistant />

</view>
