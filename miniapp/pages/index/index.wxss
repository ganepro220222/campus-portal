/* pages/index/index.wxss — 对齐 demo 首页设计 */

.home-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #EAF1FB 0%, #F5F8FC 500rpx);
}

/* ── 吸顶 Header ── */
.header {
  flex-shrink: 0;
  background: rgba(255,255,255,.94);
  padding: 12rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #E7ECF6;
  box-shadow: 0 4rpx 28rpx rgba(31,40,90,.05);
  /* 加上状态栏高度，微信会自动处理 */
}
.header-row {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  height: 72rpx;
}
.school-title-img {
  height: 52rpx;
  max-width: 70%;
  object-fit: contain;
}
.bell-btn {
  position: absolute;
  right: 0;
  top: 50%; transform: translateY(-50%);
  width: 64rpx; height: 64rpx;
  display: flex; align-items: center; justify-content: center;
  border-radius: 50%;
  position: absolute;
}
.bell-btn:active { background: #F2F7FC; }
.bell-svg { font-size: 38rpx; }
.bell-dot {
  position: absolute;
  top: 12rpx; right: 12rpx;
  width: 14rpx; height: 14rpx;
  border-radius: 50%;
  background: #BE9C44;
  border: 3rpx solid #fff;
}

/* 搜索框 */
.search-bar {
  margin-top: 16rpx;
  height: 72rpx;
  background: #F2F7FC;
  border: 1rpx solid #E7ECF6;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  padding: 0 28rpx;
  gap: 12rpx;
  color: #8A93B2;
}
.search-bar:active { background: #EDF3FB; }
.s-icon { font-size: 28rpx; }
.search-placeholder { font-size: 26rpx; color: #8A93B2; }

/* ── 可滚动内容区 ── */
.scroll-body { flex: 1; overflow: hidden; }

.wrap { padding: 0 32rpx; }

/* ── Banner ── */
.banner {
  position: relative;
  border-radius: 32rpx;
  overflow: hidden;
  height: 300rpx;
  margin-top: 24rpx;
  box-shadow: 0 16rpx 48rpx rgba(31,40,90,.12);
}
.bslide {
  width: 100%; height: 100%;
  position: relative;
  display: flex; flex-direction: column;
  justify-content: center;
  padding: 32rpx 36rpx;
  color: #fff;
  overflow: hidden;
}
.bslide.s1 { background: linear-gradient(120deg, #1E2654, #3F57B5); }
.bslide.s2 { background: linear-gradient(120deg, #243056, #4A4E86); }
.bslide.s3 { background: linear-gradient(120deg, #1B2A4A, #2E5C7A); }

.bslide-deco {
  position: absolute;
  right: -50rpx; top: -50rpx;
  width: 300rpx; height: 300rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(208,231,247,.28), transparent 70%);
  pointer-events: none;
}
.bslide-bg {
  position: absolute; inset: 0;
}
.bslide-img { width: 100%; height: 100%; object-fit: cover; opacity: .35; }

.bslide-tag {
  display: inline-flex;
  align-items: center;
  font-size: 20rpx; font-weight: 600;
  background: rgba(255,255,255,.18);
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255,255,255,.25);
  align-self: flex-start;
  margin-bottom: 14rpx;
  z-index: 2;
}
.bslide-title {
  font-size: 34rpx; font-weight: 700;
  line-height: 1.36;
  z-index: 2;
  text-shadow: 0 2rpx 12rpx rgba(0,0,0,.3);
  max-width: 90%;
}
.bslide-desc {
  font-size: 22rpx;
  opacity: .82;
  margin-top: 10rpx;
  z-index: 2;
  max-width: 88%;
}

/* 自定义指示点 */
.bdots {
  display: flex;
  justify-content: flex-end;
  padding-right: 24rpx;
  margin-top: 12rpx;
  gap: 10rpx;
}
.bdot {
  width: 12rpx; height: 12rpx;
  border-radius: 50%;
  background: rgba(43,53,110,.25);
}
.bdot-on {
  width: 28rpx;
  border-radius: 6rpx;
  background: #2B356E;
}

/* ── 公告条 ── */
.notice-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 20rpx;
  background: #fff;
  border: 1rpx solid #E7ECF6;
  border-radius: 20rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 4rpx 14rpx rgba(31,40,90,.06);
}
.notice-ic { font-size: 28rpx; flex-shrink: 0; }
.notice-text {
  flex: 1;
  font-size: 24rpx;
  color: #5A648A;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.notice-arrow { font-size: 28rpx; color: #8A93B2; }

/* ── 功能入口矩阵 ── */
.entries-wrap {
  margin-top: 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 16rpx;
  border: 1rpx solid #E7ECF6;
  box-shadow: 0 4rpx 14rpx rgba(31,40,90,.06);
}
.entries {
  display: flex;
  justify-content: space-around;
}
.entry {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.entry:active .ico { transform: translateY(-4rpx); }
.ico {
  width: 96rpx; height: 96rpx;
  border-radius: 28rpx;
  display: flex; align-items: center; justify-content: center;
}
.ico-1 { background: linear-gradient(135deg, #3F57B5, #2B356E); }
.ico-2 { background: linear-gradient(135deg, #5867B8, #39418A); }
.ico-3 { background: linear-gradient(135deg, #6E8FCB, #46639E); }
.ico-4 { background: linear-gradient(135deg, #4E7CC4, #2F5E92); }
.ico-5 { background: linear-gradient(135deg, #C0A24E, #9C7C2E); }
.ico-symbol {
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  font-family: "Noto Serif SC", serif;
}
.entry-label {
  font-size: 22rpx;
  color: #1F2547;
  font-weight: 500;
}

/* ── Section 通用 ── */
.section { margin-top: 36rpx; }
.sec-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}
.sec-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1F2547;
  position: relative;
  padding-left: 20rpx;
}
.sec-title::before {
  content: "";
  position: absolute;
  left: 0; top: 50%;
  transform: translateY(-50%);
  width: 6rpx; height: 28rpx;
  border-radius: 3rpx;
  background: linear-gradient(180deg, #3F57B5, #2B356E);
}
.sec-more {
  font-size: 24rpx;
  color: #8A93B2;
  display: flex; align-items: center;
}

/* ── 展馆横滑 ── */
.halls-scroll { width: 100%; }
.halls-inner {
  display: flex;
  gap: 20rpx;
  padding-bottom: 10rpx;
  white-space: nowrap;
}
.hall-card {
  display: inline-flex;
  align-items: flex-end;
  padding: 16rpx;
  width: 220rpx; height: 140rpx;
  border-radius: 24rpx;
  overflow: hidden;
  position: relative;
  flex-shrink: 0;
  box-shadow: 0 6rpx 20rpx rgba(31,40,90,.15);
}
.hall-card:active { opacity: .9; }
.hc1 { background: linear-gradient(135deg, #2B356E, #475BA6); }
.hc2 { background: linear-gradient(135deg, #365E8C, #2E7C8C); }
.hc3 { background: linear-gradient(135deg, #7A2E36, #A0505A); }
.hc4 { background: linear-gradient(135deg, #3F6B4A, #5C9A6B); }
.hc5 { background: linear-gradient(135deg, #5A4E86, #7E72B0); }
.hc-bg { position: absolute; inset: 0; }
.hc-img { width: 100%; height: 100%; object-fit: cover; opacity: .35; }
.hc-mask {
  position: absolute; left: 0; right: 0; bottom: 0;
  height: 70rpx;
  background: linear-gradient(transparent, rgba(12,16,36,.65));
}
.hc-name {
  position: relative; z-index: 2;
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  text-shadow: 0 2rpx 10rpx rgba(0,0,0,.3);
}

/* ── 资讯卡片 ── */
.cards { display: flex; flex-direction: column; gap: 20rpx; }
.ncard {
  display: flex;
  gap: 22rpx;
  background: #fff;
  border: 1rpx solid #E7ECF6;
  border-radius: 24rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 14rpx rgba(31,40,90,.07);
  align-items: center;
}
.ncard:active { transform: scale(.99); }
.ncard-thumb {
  flex-shrink: 0;
  width: 140rpx; height: 100rpx;
  border-radius: 16rpx;
  overflow: hidden;
  display: flex; align-items: center; justify-content: center;
}
.ncard-img { width: 100%; height: 100%; object-fit: cover; }
.ncard-body { flex: 1; }
.ncard-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2547;
  line-height: 1.45;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.ncard-meta {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 12rpx;
}
.ncard-date { font-size: 22rpx; color: #8A93B2; }

/* ── 课程卡片 ── */
.ccard {
  display: flex;
  gap: 22rpx;
  background: #fff;
  border: 1rpx solid #E7ECF6;
  border-radius: 24rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 14rpx rgba(31,40,90,.07);
  align-items: center;
}
.ccard:active { transform: scale(.99); }
.ccard-thumb {
  flex-shrink: 0;
  width: 140rpx; height: 100rpx;
  border-radius: 16rpx;
  overflow: hidden;
  display: flex; align-items: center; justify-content: center;
}
.ccard-img { width: 100%; height: 100%; object-fit: cover; }
.ccard-body { flex: 1; }
.ccard-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2547;
  line-height: 1.45;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.ccard-meta {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 12rpx;
}
.ccard-sub { font-size: 22rpx; color: #8A93B2; }

/* ── 标签胶囊 ── */
.pill {
  display: inline-block;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background: #E8F2FB;
  color: #2B356E;
  font-weight: 600;
}
.pill.gold { background: #FBF3DD; color: #9C7C2E; }
