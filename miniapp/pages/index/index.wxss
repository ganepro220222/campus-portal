/* pages/index/index.wxss — 首页 */

.home-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #EAF1FB 0%, #F5F8FC 500rpx);
}

/* ── 吸顶 Header ── */
.header {
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.94);
  backdrop-filter: blur(20rpx);
  padding: 12rpx 0 20rpx 28rpx;
  border-bottom: 1rpx solid #E7ECF6;
  box-shadow: 0 4rpx 28rpx rgba(31, 40, 90, 0.05);
}
.header-row {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  height: 76rpx;
}
.header-me {
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.header-me:active { background: #F2F7FC; }
/* 顶部标题：金色 ❖ 匾额式框衬 */
.header-title {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.ht-orn {
  font-size: 20rpx;
  line-height: 1;
  color: #BE9C44;
  opacity: 0.92;
  text-shadow: 0 1rpx 2rpx rgba(150, 110, 30, 0.28);
}
.header-name {
  font-size: 47rpx;
  font-weight: 700;
  color: var(--navy);
  letter-spacing: 6rpx;
  text-indent: 6rpx;
  white-space: nowrap;
  /* 楷体优先，书香气更足；无楷体时回退宋体 */
  font-family: "STKaiti", "KaiTi", "Kaiti SC", "楷体", "Noto Serif SC", "STSong", serif;
  /* 加粗笔画去单薄 + 墨韵纵深（不支持描边的设备优雅降级）*/
  -webkit-text-stroke: 0.5rpx var(--navy);
  text-shadow: 0 1rpx 1rpx rgba(31, 40, 90, 0.16);
}
.bell-btn {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}
.bell-btn:active { background: #F2F7FC; }
.bell-dot {
  position: absolute;
  top: 12rpx;
  right: 14rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #BE9C44;
  border: 3rpx solid #fff;
}

/* 搜索框 */
.search-bar {
  margin-top: 16rpx;
  height: 74rpx;
  background: #F2F7FC;
  border: 1rpx solid #E7ECF6;
  border-radius: 37rpx;
  display: flex;
  align-items: center;
  padding: 0 26rpx;
  gap: 14rpx;
}
.search-bar:active { background: #EDF3FB; }
.search-placeholder { font-size: 26rpx; color: #8A93B2; }

/* ── 可滚动内容区 ── */
.scroll-body { flex: 1; overflow: hidden; }
.wrap { padding: 0 32rpx; }
.scroll-bottom { height: calc(150rpx + env(safe-area-inset-bottom)); }

/* ── Banner ── */
.banner {
  position: relative;
  border-radius: 32rpx;
  overflow: hidden;
  height: 316rpx;
  margin-top: 24rpx;
  box-shadow: 0 16rpx 48rpx rgba(31, 40, 90, 0.12);
}
.bslide {
  width: 100%;
  height: 100%;
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 32rpx 40rpx;
  color: #fff;
  overflow: hidden;
}
.bslide-deco {
  position: absolute;
  right: -50rpx;
  top: -50rpx;
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(208, 231, 247, 0.28), transparent 70%);
  pointer-events: none;
}
.bslide-bg { position: absolute; left: 0; top: 0; right: 0; bottom: 0; }
.bslide-img { width: 100%; height: 100%; opacity: 0.32; }
.bslide-tag {
  display: inline-flex;
  align-items: center;
  font-size: 20rpx;
  font-weight: 600;
  background: rgba(255, 255, 255, 0.18);
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.25);
  align-self: flex-start;
  margin-bottom: 16rpx;
  z-index: 2;
}
.bslide-title {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.34;
  z-index: 2;
  text-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.3);
  max-width: 92%;
}
.bslide-desc {
  font-size: 23rpx;
  opacity: 0.85;
  margin-top: 12rpx;
  z-index: 2;
  max-width: 90%;
}
.bdots {
  display: flex;
  justify-content: flex-end;
  padding-right: 24rpx;
  margin-top: 14rpx;
  gap: 10rpx;
}
.bdot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(43, 53, 110, 0.25);
  transition: 0.3s;
}
.bdot-on { width: 30rpx; border-radius: 6rpx; background: #2B356E; }

/* ── 公告条 ── */
.notice-bar {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 22rpx;
  background: #fff;
  border: 1rpx solid #E7ECF6;
  border-radius: 20rpx;
  padding: 16rpx 22rpx;
  box-shadow: 0 4rpx 14rpx rgba(31, 40, 90, 0.06);
}
.notice-text {
  flex: 1;
  font-size: 24rpx;
  color: #5A648A;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ── 虚拟文创展厅入口 ── */
.vr-banner { margin-top: 24rpx; }
.vr-banner-inner {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 28rpx 30rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #2B356E 0%, #4A5FA8 55%, #6B7EC8 100%);
  box-shadow: 0 16rpx 40rpx rgba(43, 53, 110, 0.22);
}
.vr-banner:active { opacity: 0.92; }
.vr-ic {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.vr-text { flex: 1; min-width: 0; }
.vr-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
}
.vr-sub {
  display: block;
  font-size: 23rpx;
  color: rgba(255, 255, 255, 0.78);
  margin-top: 8rpx;
}

/* ── 功能入口矩阵 ── */
.entries-wrap {
  margin-top: 24rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 30rpx 12rpx 24rpx;
  border: 1rpx solid #E7ECF6;
  box-shadow: 0 4rpx 14rpx rgba(31, 40, 90, 0.06);
}
.entries { display: flex; justify-content: space-around; }
.entry {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  flex: 1;
}
.entry:active .ico { transform: translateY(-4rpx); }
.ico {
  width: 100rpx;
  height: 100rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 28rpx rgba(31, 40, 90, 0.16);
  transition: transform 0.15s;
}
.e1 { background: linear-gradient(135deg, #3F57B5, #2B356E); }
.e2 { background: linear-gradient(135deg, #4E7CC4, #2F5E92); }
.e3 { background: linear-gradient(135deg, #5867B8, #39418A); }
.e4 { background: linear-gradient(135deg, #6E8FCB, #46639E); }
.e5 { background: linear-gradient(135deg, #C0A24E, #9C7C2E); }
.entry-label { font-size: 23rpx; color: #1F2547; font-weight: 500; white-space: nowrap; }

/* ── Section 通用 ── */
.section { margin-top: 40rpx; }
.sec-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}
.sec-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1F2547;
  position: relative;
  padding-left: 22rpx;
}
.sec-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 30rpx;
  border-radius: 3rpx;
  background: linear-gradient(180deg, #3F57B5, #2B356E);
}
.sec-more {
  font-size: 24rpx;
  color: #8A93B2;
  display: flex;
  align-items: center;
  gap: 2rpx;
}

/* ── 展馆横滑（两层卡：封面 + 白底名）── */
.halls-scroll { width: 100%; }
.halls-inner {
  display: flex;
  gap: 22rpx;
  padding: 4rpx 0 12rpx;
  white-space: nowrap;
}
.hall-card {
  display: inline-flex;
  flex-direction: column;
  width: 240rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #fff;
  border: 1rpx solid #E7ECF6;
  box-shadow: 0 8rpx 22rpx rgba(31, 40, 90, 0.12);
  flex-shrink: 0;
}
.hall-card:active { transform: translateY(-4rpx); }
.hc-cover {
  position: relative;
  height: 150rpx;
  padding: 16rpx;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
}
.hc-bg { position: absolute; left: 0; top: 0; right: 0; bottom: 0; }
.hc-img { width: 100%; height: 100%; opacity: 0.4; }
.hc-corner { position: absolute; right: 14rpx; top: 12rpx; }
.hc-ct {
  position: relative;
  z-index: 2;
  color: #fff;
  font-size: 27rpx;
  font-weight: 700;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.3);
}
.hc-name {
  padding: 16rpx 20rpx;
  font-size: 25rpx;
  font-weight: 600;
  color: #1F2547;
}

/* ── 资讯 / 课程卡片 ── */
.cards { display: flex; flex-direction: column; gap: 20rpx; }
.ncard, .ccard {
  display: flex;
  gap: 22rpx;
  background: #fff;
  border: 1rpx solid #E7ECF6;
  border-radius: 24rpx;
  padding: 18rpx;
  box-shadow: 0 4rpx 14rpx rgba(31, 40, 90, 0.07);
  align-items: center;
  transition: transform 0.15s;
}
.ncard:active, .ccard:active { transform: scale(0.99); }
.ncard-thumb {
  flex-shrink: 0;
  width: 172rpx;
  height: 124rpx;
  border-radius: 18rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}
.ccard-thumb {
  flex-shrink: 0;
  width: 148rpx;
  height: 148rpx;
  border-radius: 18rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}
.ncard-img, .ccard-img { width: 100%; height: 100%; }
.ncard-body, .ccard-body { flex: 1; min-width: 0; }
.ncard-title, .ccard-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2547;
  line-height: 1.45;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.ncard-meta, .ccard-meta {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 14rpx;
}
.ncard-date, .ccard-sub { font-size: 22rpx; color: #8A93B2; }
