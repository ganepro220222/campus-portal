<!-- pages/login/index.wxml -->
<view class="login-page">
  <view class="glow"></view>
  <view class="stars"></view>
  <view class="wave-deco" wx:if="{{!changePasswordMode}}"></view>

  <view class="login-back" style="top: calc({{statusBarHeight}}px + 12rpx);" bindtap="onBack" hover-class="login-back-hover">
    <icon name="chevron-left" size="22" color="#ffffff" sw="2.6" />
  </view>

  <view class="login-inner">
    <view style="height: {{statusBarHeight}}px; flex-shrink: 0;"></view>

    <block wx:if="{{!changePasswordMode}}">
      <view class="seal">
        <image class="seal-img" src="/assets/images/school-badge.png" mode="aspectFit" />
      </view>

      <view class="brand">
        <view class="brand-zh serif">云端<text class="brand-zh-gold">书</text>院</view>
        <view class="brand-div">
          <view class="brand-div-line"></view>
          <text class="brand-div-orn">❖</text>
          <view class="brand-div-line brand-div-line-r"></view>
        </view>
        <view class="brand-sub serif">贵州交通职业大学 · 中华文化书院</view>
        <view class="brand-en">Guizhou Communications Polytechnic University</view>
      </view>
    </block>

    <view class="brand compact" wx:else>
      <view class="brand-zh serif">修改初始密码</view>
      <view class="brand-sub serif">为保障账号安全，首次登录须设置新密码</view>
    </view>

    <!-- 登录表单 -->
    <view class="login-form" wx:if="{{!changePasswordMode}}">
      <view class="field">
        <view class="field-ic"><icon name="user" size="18" color="rgba(214,224,248,0.7)" /></view>
        <input
          class="field-input"
          placeholder="请输入学号 / 账号"
          placeholder-class="field-ph"
          value="{{studentNo}}"
          data-field="studentNo"
          bindinput="onInput"
          maxlength="30"
        />
      </view>
      <view class="field">
        <view class="field-ic"><icon name="lock" size="18" color="rgba(214,224,248,0.7)" /></view>
        <input
          class="field-input"
          placeholder="请输入密码"
          placeholder-class="field-ph"
          password
          value="{{password}}"
          data-field="password"
          bindinput="onInput"
          maxlength="50"
        />
      </view>

      <button class="lbtn lbtn-primary" bindtap="{{bindMode ? 'onBindWxAccount' : 'onAccountLogin'}}" loading="{{loading}}" disabled="{{loading}}">
        <icon name="login" size="18" color="#2B356E" />
        <text class="lbtn-tx">{{bindMode ? '绑定学号并登录' : '登 录'}}</text>
      </button>

      <view wx:if="{{bindMode}}" class="bind-tip">首次微信登录须绑定校方导入的学号账号</view>

      <view class="divider">其他登录方式</view>

      <button class="lbtn lbtn-ghost" bindtap="onWxLogin" loading="{{loading}}" disabled="{{loading}}" wx:if="{{!bindMode}}">
        <icon name="wechat" size="20" color="#ffffff" />
        <text class="lbtn-tx">微信授权登录</text>
      </button>

      <view class="foot">
        <text class="foot-b">“马院 + 书院”协同育人 · 云端思政平台</text>
        <text class="foot-s">线上线下相结合 · 传承中华优秀传统文化</text>
      </view>
    </view>

    <!-- 改密表单 -->
    <view class="login-form" wx:else>
      <view class="field">
        <view class="field-ic"><icon name="lock" size="18" color="rgba(214,224,248,0.7)" /></view>
        <input
          class="field-input"
          placeholder="请输入当前密码（初始密码）"
          placeholder-class="field-ph"
          password
          value="{{oldPassword}}"
          data-field="oldPassword"
          bindinput="onInput"
          maxlength="50"
        />
      </view>
      <view class="field">
        <view class="field-ic"><icon name="lock" size="18" color="rgba(214,224,248,0.7)" /></view>
        <input
          class="field-input"
          placeholder="新密码（至少8位，含字母和数字）"
          placeholder-class="field-ph"
          password
          value="{{newPassword}}"
          data-field="newPassword"
          bindinput="onInput"
          maxlength="50"
        />
      </view>
      <view class="field">
        <view class="field-ic"><icon name="lock" size="18" color="rgba(214,224,248,0.7)" /></view>
        <input
          class="field-input"
          placeholder="确认新密码"
          placeholder-class="field-ph"
          password
          value="{{confirmPassword}}"
          data-field="confirmPassword"
          bindinput="onInput"
          maxlength="50"
        />
      </view>

      <button class="lbtn lbtn-primary" bindtap="onChangePassword" loading="{{loading}}" disabled="{{loading}}">
        <text class="lbtn-tx">确认修改</text>
      </button>

      <view class="bind-tip muted">修改完成后即可正常使用小程序</view>
    </view>
  </view>
</view>
