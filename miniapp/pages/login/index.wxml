<!-- pages/login/index.wxml -->
<view class="login-page">
  <!-- 光晕 / 星光 / 波浪装饰 -->
  <view class="glow"></view>
  <view class="stars"></view>
  <view class="wave-deco"></view>

  <view class="login-inner">
    <view style="height: {{statusBarHeight}}px; flex-shrink: 0;"></view>

    <!-- 校徽印章（白色徽记 + 深色底 + 金环）-->
    <view class="seal">
      <image class="seal-img" src="/assets/images/school-badge.png" mode="aspectFit" />
    </view>

    <!-- 校名 -->
    <view class="brand">
      <view class="brand-zh serif">云端书院</view>
      <view class="brand-div"></view>
      <view class="brand-sub serif">贵州交通职业大学 · 中华文化书院</view>
      <view class="brand-en">Guizhou Communications Polytechnic University</view>
    </view>

    <!-- 登录表单 -->
    <view class="login-form">
      <view class="field">
        <view class="field-ic"><icon name="user" size="18" color="rgba(214,224,248,0.7)" /></view>
        <input
          class="field-input"
          placeholder="请输入学号 / 账号"
          placeholder-class="field-ph"
          value="{{studentNo}}"
          data-field="studentNo"
          bindinput="onInput"
          maxlength="30"
        />
      </view>
      <view class="field">
        <view class="field-ic"><icon name="lock" size="18" color="rgba(214,224,248,0.7)" /></view>
        <input
          class="field-input"
          placeholder="请输入密码"
          placeholder-class="field-ph"
          password
          value="{{password}}"
          data-field="password"
          bindinput="onInput"
          maxlength="50"
        />
      </view>

      <button class="lbtn lbtn-primary" bindtap="onAccountLogin" loading="{{loading}}" disabled="{{loading}}">
        <icon name="login" size="18" color="#2B356E" />
        <text class="lbtn-tx">登 录</text>
      </button>

      <view class="divider">其他登录方式</view>

      <button class="lbtn lbtn-ghost" bindtap="onWxLogin" loading="{{loading}}" disabled="{{loading}}">
        <icon name="wechat" size="20" color="#ffffff" />
        <text class="lbtn-tx">微信授权登录</text>
      </button>

      <view class="foot">
        <text class="foot-b">“马院 + 书院”协同育人 · 云端思政平台</text>
        <text class="foot-s">线上线下相结合 · 传承中华优秀传统文化</text>
      </view>
    </view>
  </view>
</view>
