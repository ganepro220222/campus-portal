<!-- pages/login/index.wxml -->
<view class="login-page">
  <!-- 星光背景 -->
  <view class="stars"></view>
  <view class="glow"></view>

  <view class="login-inner">
    <!-- 状态栏占位 -->
    <view style="height: {{statusBarHeight}}px; flex-shrink: 0;"></view>

    <!-- 校徽 -->
    <view class="seal">
      <image class="seal-img" src="/assets/images/school-badge.png" mode="aspectFit" />
    </view>

    <!-- 校名 -->
    <view class="brand">
      <view class="brand-zh serif">云端书院</view>
      <view class="brand-divider"></view>
      <view class="brand-sub">贵州交通职业大学 · 中华文化书院</view>
      <view class="brand-en">Guizhou Communications Polytechnic University</view>
    </view>

    <!-- 登录表单区 -->
    <view class="login-form">

      <!-- Tab 切换 -->
      <view class="tab-row">
        <view class="tab-item {{activeTab === 'wx' ? 'tab-on' : ''}}" bindtap="switchTab" data-tab="wx">微信登录</view>
        <view class="tab-item {{activeTab === 'account' ? 'tab-on' : ''}}" bindtap="switchTab" data-tab="account">学号登录</view>
      </view>

      <!-- 微信登录 -->
      <view wx:if="{{activeTab === 'wx'}}" class="panel">
        <button class="btn-primary-glass" open-type="getUserInfo" bindtap="onWxLogin" loading="{{loading}}" disabled="{{loading}}">
          <view class="btn-icon">
            <view class="wx-icon">
              <text>✓</text>
            </view>
          </view>
          微信一键登录
        </button>
        <button class="btn-ghost-glass" bindtap="switchTabAccount">学号 / 账号登录</button>
      </view>

      <!-- 账号登录 -->
      <view wx:if="{{activeTab === 'account'}}" class="panel">
        <view class="field-glass">
          <view class="field-icon">
            <text class="iconfont icon-user"></text>
          </view>
          <input
            class="field-input"
            placeholder="请输入学号或账号"
            placeholder-class="field-placeholder"
            value="{{studentNo}}"
            data-field="studentNo"
            bindinput="onInput"
            maxlength="30"
          />
        </view>
        <view class="field-glass">
          <view class="field-icon">
            <text class="iconfont icon-lock"></text>
          </view>
          <input
            class="field-input"
            placeholder="请输入密码"
            placeholder-class="field-placeholder"
            password="{{!pwdVisible}}"
            value="{{password}}"
            data-field="password"
            bindinput="onInput"
            maxlength="50"
          />
          <text class="eye-toggle" bindtap="togglePwd">{{pwdVisible ? '●' : '○'}}</text>
        </view>
        <button class="btn-gold-login" bindtap="onAccountLogin" loading="{{loading}}" disabled="{{loading}}">
          登 录
        </button>
        <view class="back-wx" bindtap="switchTabWx">← 返回微信登录</view>
      </view>

    </view>

    <view class="footer-tip">登录即代表同意《用户隐私政策》</view>
  </view>

  <!-- 底部波浪装饰 -->
  <view class="wave-deco"></view>
</view>
