/* pages/login/index.wxss — 深海军蓝夜空登录风格 */

.login-page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  background: radial-gradient(120% 80% at 50% 8%,
    #0E1430 0%, #1A2150 38%, #2B356E 78%, #313C7C 100%);
  display: flex;
  flex-direction: column;
}

/* 星光背景 */
.stars {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background-image:
    radial-gradient(2rpx 2rpx at 20% 22%, rgba(255,255,255,.55), transparent),
    radial-gradient(1.6rpx 1.6rpx at 70% 16%, rgba(255,255,255,.45), transparent),
    radial-gradient(2rpx 2rpx at 84% 30%, rgba(255,255,255,.5), transparent),
    radial-gradient(1.4rpx 1.4rpx at 35% 12%, rgba(255,255,255,.4), transparent),
    radial-gradient(1.2rpx 1.2rpx at 55% 8%, rgba(255,255,255,.35), transparent),
    radial-gradient(1.8rpx 1.8rpx at 90% 45%, rgba(255,255,255,.4), transparent),
    radial-gradient(1.2rpx 1.2rpx at 10% 60%, rgba(255,255,255,.3), transparent);
  opacity: .7;
  pointer-events: none;
}

/* 顶部光晕 */
.glow {
  position: absolute;
  top: 60rpx; left: 50%;
  transform: translateX(-50%);
  width: 600rpx; height: 600rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(208,231,247,.28) 0%, rgba(208,231,247,0) 65%);
  filter: blur(12rpx);
  pointer-events: none;
}

.login-inner {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 60rpx 40rpx;
  min-height: 100vh;
}

/* ── 校徽（白底圆形徽章 + 金色光圈）── */
.seal {
  width: 220rpx; height: 220rpx;
  border-radius: 50%;
  margin-top: 40rpx;
  background: #FFFFFF;
  display: flex; align-items: center; justify-content: center;
  box-shadow:
    0 0 0 2rpx rgba(190,156,68,.6),
    0 24rpx 80rpx rgba(8,12,30,.50),
    0 0 80rpx rgba(150,180,235,.40);
  position: relative;
  flex-shrink: 0;
}
.seal::after {
  content: "";
  position: absolute;
  inset: -10rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(190,156,68,.45);
}
.seal-img {
  width: 200rpx; height: 200rpx;
  object-fit: contain;
}

/* ── 校名品牌区 ── */
.brand {
  margin-top: 40rpx;
  text-align: center;
}
.brand-zh {
  color: #fff;
  font-size: 56rpx;
  font-weight: 700;
  letter-spacing: 10rpx;
  text-indent: 10rpx;
  text-shadow: 0 4rpx 28rpx rgba(0,0,0,.35);
}
.brand-divider {
  width: 200rpx;
  height: 1rpx;
  margin: 22rpx auto 20rpx;
  background: linear-gradient(90deg, transparent, rgba(190,156,68,.85), transparent);
  position: relative;
}
.brand-sub {
  color: rgba(214,224,248,.92);
  font-size: 24rpx;
  letter-spacing: 4rpx;
}
.brand-en {
  color: rgba(170,184,224,.7);
  font-size: 18rpx;
  margin-top: 10rpx;
  letter-spacing: 1rpx;
}

/* ── 登录表单区 ── */
.login-form {
  width: 100%;
  margin-top: auto;
  padding-top: 40rpx;
}

/* Tab 切换 */
.tab-row {
  display: flex;
  background: rgba(255,255,255,.10);
  border: 1rpx solid rgba(255,255,255,.18);
  border-radius: 40rpx;
  padding: 6rpx;
  margin-bottom: 32rpx;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 28rpx;
  color: rgba(214,224,248,.65);
  border-radius: 36rpx;
  transition: all .2s;
}
.tab-on {
  background: rgba(255,255,255,.92);
  color: #2B356E;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,.12);
}

.panel { width: 100%; }

/* 玻璃态输入框 */
.field-glass {
  display: flex;
  align-items: center;
  height: 96rpx;
  background: rgba(255,255,255,.10);
  border: 1rpx solid rgba(255,255,255,.18);
  border-radius: 24rpx;
  padding: 0 28rpx 0 20rpx;
  margin-bottom: 22rpx;
  backdrop-filter: blur(6px);
}
.field-icon {
  width: 44rpx; height: 44rpx;
  display: flex; align-items: center; justify-content: center;
  color: rgba(214,224,248,.65);
  margin-right: 14rpx;
  font-size: 36rpx;
}
.field-input {
  flex: 1;
  height: 96rpx;
  font-size: 28rpx;
  color: #fff;
  background: transparent;
}
.field-placeholder { color: rgba(214,224,248,.50); }
.eye-toggle {
  font-size: 30rpx;
  color: rgba(214,224,248,.6);
  padding: 10rpx;
}

/* 主按钮：白色/玻璃（微信登录） */
.btn-primary-glass {
  width: 100%; height: 96rpx;
  background: linear-gradient(135deg, rgba(255,255,255,.95), rgba(240,244,255,.9));
  color: #2B356E;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 12rpx 36rpx rgba(255,255,255,.18);
  margin-bottom: 20rpx;
}

/* 辅助按钮：边框透明（切换学号登录） */
.btn-ghost-glass {
  width: 100%; height: 96rpx;
  background: rgba(255,255,255,.10);
  color: #fff;
  border-radius: 48rpx;
  font-size: 28rpx;
  border: 1rpx solid rgba(255,255,255,.28);
}

/* 金色登录按钮 */
.btn-gold-login {
  width: 100%; height: 96rpx;
  background: linear-gradient(135deg, #CDA94E, #B58A2F);
  color: #fff;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
  box-shadow: 0 12rpx 36rpx rgba(150,110,30,.35);
  margin-top: 8rpx;
}

.back-wx {
  text-align: center;
  color: rgba(214,224,248,.6);
  font-size: 24rpx;
  margin-top: 28rpx;
}

.footer-tip {
  margin-top: 40rpx;
  text-align: center;
  color: rgba(170,184,224,.6);
  font-size: 22rpx;
  letter-spacing: 2rpx;
  line-height: 1.7;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 底部波浪装饰 */
.wave-deco {
  position: absolute;
  left: 0; right: 0; bottom: 0;
  height: 120rpx;
  background: linear-gradient(transparent, rgba(43,53,110,.3));
  pointer-events: none;
}
