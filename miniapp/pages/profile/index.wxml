<!-- pages/profile/index.wxml -->
<view class="page">

  <!-- 未登录状态 -->
  <view wx:if="{{!isLoggedIn}}" class="guest-panel" bindtap="onLoginTap">
    <image class="guest-avatar" src="/assets/icons/avatar-default.png" mode="aspectFill" />
    <text class="guest-tip">点击登录，解锁全部功能</text>
    <view class="login-btn">立即登录</view>
  </view>

  <!-- 已登录：用户信息 -->
  <view wx:if="{{isLoggedIn}}" class="user-panel">
    <image class="avatar" src="{{userInfo.avatar || '/assets/icons/avatar-default.png'}}" mode="aspectFill" />
    <view class="user-info">
      <text class="nickname">{{userInfo.nickname || '书院用户'}}</text>
      <text class="college">{{userInfo.college || ''}}</text>
    </view>
    <view class="points-badge">
      <text class="points-num">{{stats.points}}</text>
      <text class="points-label">积分</text>
    </view>
  </view>

  <!-- 数据统计卡 -->
  <view wx:if="{{isLoggedIn}}" class="stats-card">
    <view class="stat-item" bindtap="onFavoritesTap">
      <text class="stat-num">{{stats.favorites}}</text>
      <text class="stat-label">收藏</text>
    </view>
    <view class="stat-divider" />
    <view class="stat-item" bindtap="onEnrollsTap">
      <text class="stat-num">{{stats.enrolls}}</text>
      <text class="stat-label">报名</text>
    </view>
    <view class="stat-divider" />
    <view class="stat-item" bindtap="onDownloadsTap">
      <text class="stat-num">{{stats.downloads}}</text>
      <text class="stat-label">下载</text>
    </view>
    <view class="stat-divider" />
    <view class="stat-item" bindtap="onFootprintTap">
      <text class="stat-num">足迹</text>
      <text class="stat-label">学习</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="onBadgeTap">
      <text class="menu-icon">🏅</text>
      <text class="menu-text">文化徽章</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onFeedbackTap">
      <text class="menu-icon">💬</text>
      <text class="menu-text">意见反馈</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view wx:if="{{isLoggedIn}}" class="logout-area">
    <button class="logout-btn" bindtap="onLogout">退出登录</button>
  </view>

  <view class="safe-bottom" />
</view>
