<!-- pages/profile/index.wxml -->
<view class="profile-page">

  <!-- 顶部头区 -->
  <view class="hero">
    <view class="hero-deco"></view>
    <block wx:if="{{isLoggedIn}}">
      <view class="hero-row">
        <view class="avatar">
          <image wx:if="{{userInfo.avatar}}" src="{{userInfo.avatar}}" mode="aspectFill" class="avatar-img" />
          <icon wx:else name="user-circle" size="40" color="#ffffff" />
        </view>
        <view class="hero-info">
          <text class="nickname">{{userInfo.nickname || '书院用户'}}</text>
          <text class="college">{{userInfo.college || '贵州交通职业大学 · 中华文化书院'}}</text>
        </view>
        <view class="points">
          <text class="points-num">{{stats.points || 0}}</text>
          <text class="points-lbl">积分</text>
        </view>
      </view>
    </block>
    <block wx:else>
      <view class="hero-row" bindtap="onLoginTap">
        <view class="avatar"><icon name="user-circle" size="40" color="#ffffff" /></view>
        <view class="hero-info">
          <text class="nickname">点击登录</text>
          <text class="college">解锁收藏 · 报名 · 学习足迹</text>
        </view>
        <view class="login-chip">登录<icon name="chevron-right" size="14" color="#ffffff" /></view>
      </view>
    </block>
  </view>

  <!-- 数据统计 -->
  <view wx:if="{{isLoggedIn}}" class="stats-card">
    <view class="stat" bindtap="onStatTap" data-type="favorites"><text class="stat-num">{{stats.favorites || 0}}</text><text class="stat-lbl">收藏</text></view>
    <view class="stat-dv"></view>
    <view class="stat" bindtap="onStatTap" data-type="enrolls"><text class="stat-num">{{stats.enrolls || 0}}</text><text class="stat-lbl">报名</text></view>
    <view class="stat-dv"></view>
    <view class="stat" bindtap="onStatTap" data-type="downloads"><text class="stat-num">{{stats.downloads || 0}}</text><text class="stat-lbl">下载</text></view>
    <view class="stat-dv"></view>
    <view class="stat" bindtap="onStatTap" data-type="footprints"><view class="stat-ic"><icon name="footprint" size="26" color="#2B356E" /></view><text class="stat-lbl">足迹</text></view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu">
    <view class="menu-item" bindtap="onAiChat">
      <view class="mi-ic mi-blue"><icon name="robot" size="20" color="#ffffff" /></view>
      <text class="mi-tx">AI 文化问答</text>
      <icon name="chevron-right" size="16" color="#C3CCE0" />
    </view>
    <view class="menu-item" bindtap="onStatTap" data-type="badges">
      <view class="mi-ic mi-gold"><icon name="medal" size="20" color="#ffffff" /></view>
      <text class="mi-tx">文化徽章</text>
      <icon name="chevron-right" size="16" color="#C3CCE0" />
    </view>
    <view class="menu-item" bindtap="onFeedback">
      <view class="mi-ic mi-blue"><icon name="chat" size="20" color="#ffffff" /></view>
      <text class="mi-tx">意见反馈</text>
      <icon name="chevron-right" size="16" color="#C3CCE0" />
    </view>
    <view class="menu-item" bindtap="onAbout">
      <view class="mi-ic mi-slate"><icon name="grid" size="20" color="#ffffff" /></view>
      <text class="mi-tx">关于云端书院</text>
      <icon name="chevron-right" size="16" color="#C3CCE0" />
    </view>
  </view>

  <view wx:if="{{isLoggedIn}}" class="logout-area">
    <button class="logout-btn" bindtap="onLogout">
      <icon name="logout" size="18" color="#C0392B" />
      <text>退出登录</text>
    </button>
  </view>

  <view class="safe-bottom"></view>
</view>
