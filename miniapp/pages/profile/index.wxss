/* pages/profile/index.wxss — 深海军蓝用户中心 */

.page { background: #F5F8FC; min-height: 100vh; }

/* 未登录 */
.guest-panel {
  display: flex; flex-direction: column; align-items: center;
  padding: 80rpx 0 60rpx;
  background: linear-gradient(135deg, #1E2654, #3F57B5);
}
.guest-avatar {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  background: rgba(255,255,255,.2);
  border: 2rpx solid rgba(255,255,255,.4);
}
.guest-tip { font-size: 28rpx; color: rgba(255,255,255,.9); margin: 20rpx 0 0; }
.login-btn {
  margin-top: 28rpx;
  background: rgba(255,255,255,.92); color: #2B356E;
  font-size: 28rpx; font-weight: 700;
  padding: 14rpx 56rpx; border-radius: 40rpx;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,.12);
}

/* 用户信息栏 */
.user-panel {
  display: flex; align-items: center;
  padding: 50rpx 36rpx 40rpx;
  background: linear-gradient(135deg, #1E2654, #3F57B5);
  position: relative; overflow: hidden;
}
.user-panel::after {
  content: "";
  position: absolute; right: -40rpx; top: -40rpx;
  width: 280rpx; height: 280rpx; border-radius: 50%;
  background: radial-gradient(circle, rgba(208,231,247,.18), transparent 70%);
  pointer-events: none;
}
.avatar {
  width: 110rpx; height: 110rpx; border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,.55);
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,.2);
}
.user-info { flex: 1; margin-left: 28rpx; }
.nickname { display: block; font-size: 34rpx; font-weight: 700; color: #fff; }
.college  { display: block; font-size: 22rpx; color: rgba(255,255,255,.75); margin-top: 8rpx; }
.points-badge {
  display: flex; flex-direction: column; align-items: center;
  background: rgba(190,156,68,.22);
  border: 1rpx solid rgba(190,156,68,.5);
  border-radius: 16rpx; padding: 12rpx 24rpx;
}
.points-num   { font-size: 34rpx; font-weight: 700; color: #E7D9AE; }
.points-label { font-size: 20rpx; color: rgba(231,217,174,.75); }

/* 统计卡 */
.stats-card {
  display: flex; align-items: center;
  background: #fff; margin: 0 32rpx;
  border-radius: 0 0 24rpx 24rpx;
  padding: 36rpx 0;
  box-shadow: 0 8rpx 28rpx rgba(31,40,90,.10);
}
.stat-item    { flex: 1; display: flex; flex-direction: column; align-items: center; }
.stat-num     { font-size: 40rpx; font-weight: 700; color: #2B356E; }
.stat-label   { font-size: 22rpx; color: #8A93B2; margin-top: 6rpx; }
.stat-divider { width: 1rpx; height: 44rpx; background: #E7ECF6; }

/* 菜单 */
.menu-section {
  background: #fff; margin: 28rpx 32rpx 0;
  border-radius: 24rpx; overflow: hidden;
  border: 1rpx solid #E7ECF6;
  box-shadow: 0 4rpx 14rpx rgba(31,40,90,.06);
}
.menu-item {
  display: flex; align-items: center;
  padding: 34rpx 32rpx;
  border-bottom: 1rpx solid #F5F8FC;
}
.menu-item:last-child { border-bottom: none; }
.menu-item:active { background: #F2F7FC; }
.menu-icon  { font-size: 36rpx; margin-right: 24rpx; }
.menu-text  { flex: 1; font-size: 30rpx; color: #1F2547; }
.menu-arrow { font-size: 28rpx; color: #8A93B2; }

/* 退出 */
.logout-area { padding: 40rpx 32rpx 0; }
.logout-btn {
  background: #fff; color: #FF4D4F;
  border: 1rpx solid rgba(255,77,79,.35);
  border-radius: 44rpx; font-size: 28rpx;
  height: 88rpx; line-height: 88rpx;
}
