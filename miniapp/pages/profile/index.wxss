/* pages/profile/index.wxss — 个人中心 */
.profile-page { min-height: 100vh; background: #F5F8FC; }

/* 顶部头区 */
.hero {
  position: relative;
  overflow: hidden;
  padding: 48rpx 36rpx 96rpx;
  background: linear-gradient(135deg, #1E2654, #3F57B5);
}
.hero-deco {
  position: absolute;
  right: -60rpx; top: -60rpx;
  width: 300rpx; height: 300rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(208, 231, 247, 0.2), transparent 70%);
  pointer-events: none;
}
.hero-row { position: relative; z-index: 2; display: flex; align-items: center; }
.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.55);
  background: linear-gradient(135deg, #5C72C9, #2B356E);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.2);
  flex-shrink: 0;
}
.avatar-img { width: 100%; height: 100%; }
.hero-info { flex: 1; margin-left: 26rpx; min-width: 0; }
.nickname { display: block; font-size: 34rpx; font-weight: 700; color: #fff; }
.college {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.points {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(190, 156, 68, 0.22);
  border: 1rpx solid rgba(190, 156, 68, 0.5);
  border-radius: 16rpx;
  padding: 12rpx 24rpx;
  flex-shrink: 0;
}
.points-num { font-size: 34rpx; font-weight: 700; color: #E7D9AE; }
.points-lbl { font-size: 20rpx; color: rgba(231, 217, 174, 0.75); }
.login-chip {
  display: flex;
  align-items: center;
  gap: 2rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #2B356E;
  font-size: 26rpx;
  font-weight: 700;
  padding: 12rpx 26rpx;
  border-radius: 40rpx;
  flex-shrink: 0;
}

/* 统计卡（上浮覆盖 hero 底部）*/
.stats-card {
  position: relative;
  z-index: 3;
  display: flex;
  align-items: center;
  background: #fff;
  margin: -56rpx 32rpx 0;
  border-radius: 28rpx;
  padding: 34rpx 0;
  box-shadow: 0 12rpx 32rpx rgba(31, 40, 90, 0.12);
}
.stat { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 6rpx; }
.stat-num { font-size: 40rpx; font-weight: 700; color: #2B356E; line-height: 1; }
.stat-ic { height: 40rpx; display: flex; align-items: center; }
.stat-lbl { font-size: 22rpx; color: #8A93B2; }
.stat-dv { width: 1rpx; height: 48rpx; background: #E7ECF6; }

/* 菜单 */
.menu {
  background: #fff;
  margin: 28rpx 32rpx 0;
  border-radius: 28rpx;
  overflow: hidden;
  border: 1rpx solid #E7ECF6;
  box-shadow: 0 4rpx 14rpx rgba(31, 40, 90, 0.06);
}
.menu-item {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #F2F5FB;
}
.menu-item:last-child { border-bottom: none; }
.menu-item:active { background: #F7FAFE; }
.mi-ic {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.mi-gold { background: linear-gradient(135deg, #C0A24E, #9C7C2E); }
.mi-blue { background: linear-gradient(135deg, #4E7CC4, #2F5E92); }
.mi-slate { background: linear-gradient(135deg, #5867B8, #39418A); }
.mi-tx { flex: 1; font-size: 29rpx; color: #1F2547; }
.mi-badge {
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  padding: 0 10rpx;
  border-radius: 18rpx;
  background: #BE9C44;
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  text-align: center;
  margin-right: 8rpx;
}

/* 退出 */
.logout-area { padding: 44rpx 32rpx 0; }
.logout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  background: #fff;
  color: #C0392B;
  border: 1rpx solid rgba(192, 57, 43, 0.3);
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
  height: 88rpx;
}
.logout-btn::after { border: none; }

.safe-bottom { height: calc(40rpx + env(safe-area-inset-bottom)); }
